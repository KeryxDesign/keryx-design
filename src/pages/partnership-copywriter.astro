---
import Layout from "../layouts/Layout.astro";
import { localPath } from "../lib/i18n";
import FAQAccordion from "../components/react/FAQAccordion";
import davidePhoto from "../assets/davide-founder.webp";
import danielPorroPhoto from "../assets/testimonials/daniel-porro.webp";
import nicolaSerafiniPhoto from "../assets/testimonials/nicola-serafini.webp";

const lang = "en";
const questionnaireUrl = "https://tally.so/r/w4RO45";
const whatsappUrl = `https://wa.me/3550695822380?text=${encodeURIComponent("Hi, I'm a copywriter interested in the partnership program")}`;

const faqs = [
  {
    question: "Is it legal to take commissions on projects?",
    answer: "Absolutely yes. It's a standard referral/brokerage model. You invoice for \"marketing consulting\" or \"commercial brokerage\". Zero tax issues.",
  },
  {
    question: "Does the client need to know you collaborate with an external designer?",
    answer: "TIER 1 (Referral): Yes, the client knows they work with Keryx for design.\n\nTIER 2 (White Label): No, the client thinks you have an internal team. It's standard practice in agencies.",
  },
  {
    question: "What happens if the client is not satisfied with the design?",
    answer: "TIER 1: Client deals with us, you're not responsible. 1 substantial change + 1 revision included in price.\n\nTIER 2: You act as intermediary between client and us. You manage communication, we execute technical changes. Revisions included: 1 change + 1 revision. Extra: \u20AC70 each.",
  },
  {
    question: "Can I just do referrals without managing design?",
    answer: "Yes, Tier 1 is made exactly for this. Send client, get 25%, zero management on your part.",
  },
  {
    question: "Can I switch from Tier 1 to Tier 2?",
    answer: "Yes, whenever you want. Many copywriters start with Tier 1 to test the workflow, then switch to Tier 2 when they feel ready to manage complete packages.",
  },
  {
    question: "How long does it take to receive commissions?",
    answer: "TIER 1: Within 7 business days of client payment to Keryx.\n\nTIER 2: You collect directly from client, then pay us per agreement (upfront or post-delivery).",
  },
  {
    question: "Is there a minimum number of projects per month?",
    answer: "No. Collaborate when you want, if you want. No monthly quotas, binding contracts, or volume obligations.",
  },
  {
    question: "In Tier 2, can I decide how much to resell the design for?",
    answer: "Yes, completely. We give you fixed partner price, you resell to client at whatever price you prefer. Typical margins: 35-50%, but you can do more with premium clients.",
  },
  {
    question: "Will Keryx ever talk to my client in Tier 2?",
    answer: "NEVER. In white label we only work with you. You're the only point of contact with the client. Files delivered without Keryx branding.",
  },
  {
    question: "Can I see examples of your work before applying?",
    answer: "Yes, go to the Case Studies section of the site. Every project includes real performance data (conversions, ROI, sales generated).",
  },
  {
    question: "Do you also offer copywriting?",
    answer: "Yes, if copy support is needed for complex projects. But the focus of the partnership is on design\u2014you're the copy, we're the design.",
  },
  {
    question: "How do I differentiate from other copywriters if everyone can do the partnership?",
    answer: "We only accept 2 partners per month to maintain service quality. Not everyone gets approved. Selection is rigorous: we evaluate professionalism, type of clients, approach to work. If you get in, you have access to a workflow that very few copywriters can offer.",
  },
];
---

<Layout
  title="Copywriter Partnership | Keryx Design"
  description="Partner with Keryx Design: offer complete service to your clients and earn commissions on every project. Two collaboration tiers for copywriters."
  lang={lang}
>
  <!-- Hero Section -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-24 px-4 bg-marble">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-foreground mb-6 leading-tight">
        The Complete Copywriter Doesn&rsquo;t Work Alone: They Have a Partner Who Makes Them Earn More
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground mb-8 max-w-3xl mx-auto">
        With AI you write copy faster. But without a direct response designer, you&rsquo;re limping. Partner with us: offer complete service to your clients and earn commissions on every project.
      </p>
      <div class="space-y-4 text-left max-w-3xl mx-auto mb-10">
        <p class="text-muted-foreground leading-relaxed">
          AI has changed the game: now you can write more copy, faster, with higher quality.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          But your clients don&rsquo;t just want text. They want ready-to-sell materials. And you lose deals because you don&rsquo;t have a direct response designer who amplifies your work&mdash;or worse, you outsource to designers who sabotage it.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          We solve this: you become the complete partner clients are looking for, and you also earn on design.
        </p>
      </div>
      <a href={questionnaireUrl} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-bold text-white text-lg px-10 py-4 rounded-lg shadow-lg transition-all hover:shadow-xl"
        style="background: linear-gradient(135deg, #D4A84B 0%, #B8942E 100%);"
      >
        Apply as Partner and Start Earning
      </a>
      <p class="text-sm text-gold mt-4 font-medium">
        &#9889; We only accept 2 new copywriter partners per month
      </p>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-16 md:py-24 px-4 bg-primary text-primary-foreground">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-4xl font-bold text-primary-foreground text-center mb-6">
        AI Gave You Superpowers. But You&rsquo;re Missing The Last Piece.
      </h2>
      <p class="text-primary-foreground/80 text-center max-w-3xl mx-auto mb-12 whitespace-pre-line">ChatGPT, Claude, Gemini: you write headlines in 30 seconds, structure sales pages in an hour, produce infinite variations. You&rsquo;re faster, more prolific, more competitive.

But when the client asks &lsquo;Ok, and who does my layout?&rsquo;, what do you answer?</p>
      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <!-- Box 1: AlertTriangle -->
        <div class="bg-primary-foreground/5 border border-gold/30 rounded-xl p-6">
          <div class="w-12 h-12 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-bold text-primary-foreground mb-3">You Lose Deals Due to Lack of Design</h3>
          <p class="text-primary-foreground/70 text-sm">The client wants the complete package. You say &ldquo;you handle the design&rdquo; and they go to an agency that offers everything. You lose &euro;3,000-5,000 each time.</p>
        </div>
        <!-- Box 2: TrendingDown -->
        <div class="bg-primary-foreground/5 border border-gold/30 rounded-xl p-6">
          <div class="w-12 h-12 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>
          </div>
          <h3 class="text-lg font-bold text-primary-foreground mb-3">You Outsource to Designers Who Ruin the Copy</h3>
          <p class="text-primary-foreground/70 text-sm">You find a designer on Fiverr. It&rsquo;s cheap, but they compress the text, hide the CTA, reverse priorities. The client sees low conversions and blames your copy.</p>
        </div>
        <!-- Box 3: XCircle -->
        <div class="bg-primary-foreground/5 border border-gold/30 rounded-xl p-6">
          <div class="w-12 h-12 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
          </div>
          <h3 class="text-lg font-bold text-primary-foreground mb-3">You Can&rsquo;t Scale Beyond Your Time</h3>
          <p class="text-primary-foreground/70 text-sm">You write faster with AI, but bottlenecks remain: design management, revisions, deliveries. You don&rsquo;t earn more because you can&rsquo;t offer more.</p>
        </div>
      </div>
      <p class="text-center font-bold text-gold text-lg max-w-3xl mx-auto">
        The copywriter who scales in 2025 isn&rsquo;t the one who writes faster. It&rsquo;s the one who offers complete results&mdash;and earns on the entire process.
      </p>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="py-16 md:py-24 px-4 bg-marble">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-4xl font-bold text-foreground text-center mb-6">
        Partner With Us, Offer Complete Service, Earn on Every Project
      </h2>
      <p class="text-muted-foreground text-center max-w-3xl mx-auto mb-12 whitespace-pre-line">You don&rsquo;t need to hire a designer. You don&rsquo;t need to learn InDesign. You don&rsquo;t need to lose margins.

Become our partner: you sell (copy + design), we execute the design, you earn commissions on everything. The client gets materials that sell, you become the complete consultant they&rsquo;re looking for.</p>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <!-- TrendingUp -->
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Scale Faster</h3>
          <p class="text-muted-foreground text-sm">Offer complete packages without hiring a team. Close bigger deals. Clients see you as a &ldquo;strategic consultant&rdquo;, not &ldquo;just copy&rdquo;.</p>
        </div>
        <!-- Zap -->
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Earn on Design Too</h3>
          <p class="text-muted-foreground text-sm">Every project that goes through us generates commission for you&mdash;even if you don&rsquo;t write a word. The more clients you send, the more you earn. Real passive income.</p>
        </div>
        <!-- DollarSign -->
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Zero Risk, Zero Overhead</h3>
          <p class="text-muted-foreground text-sm">You don&rsquo;t pay salaries, software, training. We handle production, revisions, deliveries. You focus on copy and sales.</p>
        </div>
      </div>
      <!-- Quote block -->
      <div class="bg-gold/5 border border-gold/20 rounded-xl p-8 max-w-4xl mx-auto flex flex-col md:flex-row gap-6 items-start">
        <img
          src={davidePhoto.src}
          alt="Davide Filippini"
          class="w-24 h-24 rounded-full object-cover border-2 border-gold/30 flex-shrink-0"
        />
        <div>
          <p class="text-foreground italic whitespace-pre-line mb-4">For 3 years I led the graphic department of Metodo Merenda, the largest Italian company for direct marketing training. I managed a team and was the link between salespeople, external clients, internal work, copy, web and printing.

That workflow became the Keryx method: frictionless collaboration, clear communication, zero bottlenecks. Now I offer it to copywriters who want to scale without hiring.</p>
          <p class="text-gold font-semibold">&mdash; Davide Filippini, Founder</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Earnings Section -->
  <section class="py-16 md:py-24 px-4 bg-primary">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-4xl font-bold text-primary-foreground text-center mb-6">
        Two Ways to Collaborate, You Choose Which
      </h2>
      <p class="text-primary-foreground/80 text-center max-w-3xl mx-auto mb-12">
        There&rsquo;s no one-size-fits-all model. Some copywriters want zero hassle and easy commissions. Others want total control and high margins. You can do both, or switch from one to the other whenever you want.
      </p>
      <div class="grid lg:grid-cols-2 gap-8 mb-10">
        <!-- Tier 1 Card -->
        <div class="bg-primary-foreground border-4 border-primary/50 rounded-xl overflow-hidden shadow-xl">
          <div class="bg-primary px-6 py-4">
            <span class="text-sm font-bold text-primary-foreground uppercase tracking-wider">ZERO HASSLE</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-foreground mb-6">TIER 1 - SEND CLIENTS, GET 25%</h3>

            <div class="mb-6">
              <h4 class="font-bold text-foreground mb-3">THE MODEL:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>Client needs design &rarr; You introduce Keryx</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>Client works directly with us</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>You get 25% commission on project value</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>Zero management, zero responsibility</li>
              </ul>
            </div>

            <div class="mb-6">
              <h4 class="font-bold text-foreground mb-3">THE CLIENT KNOWS THAT:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>You did the copy</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>Keryx does the design</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-primary">&bull;</span>They&rsquo;re two separate suppliers</li>
              </ul>
            </div>

            <div class="bg-primary/5 rounded-lg p-4 mb-6">
              <h4 class="font-bold text-foreground mb-3">PRACTICAL EXAMPLE:</h4>
              <p class="text-sm text-muted-foreground whitespace-pre-line mb-3">Client commissions sales page from Keryx (&euro;1,500)
&rarr; You earn &euro;375 for an introduction</p>
              <p class="text-sm font-semibold text-foreground mb-2">Send 3-4 referrals/month:</p>
              <ul class="space-y-1 mb-3">
                <li class="text-sm text-muted-foreground">1 flyer (&euro;600) &rarr; &euro;150</li>
                <li class="text-sm text-muted-foreground">1 sales page (&euro;1,500) &rarr; &euro;375</li>
                <li class="text-sm text-muted-foreground">1 postcard (&euro;700) &rarr; &euro;175</li>
              </ul>
              <p class="text-sm font-bold text-gold">MONTHLY TOTAL: &euro;700-1,000 passive income</p>
              <p class="text-sm font-bold text-gold">YEARLY TOTAL: &euro;8,400-12,000</p>
            </div>

            <div>
              <h4 class="font-bold text-foreground mb-3">PERFECT IF:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You want extra income without complications
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You don&rsquo;t want to manage design revisions
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You have spot or non-recurring clients
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You&rsquo;re starting out and want to test the model
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Tier 2 Card -->
        <div class="bg-primary-foreground border-4 border-gold rounded-xl overflow-hidden shadow-xl ring-2 ring-gold/20">
          <div class="bg-gold px-6 py-4">
            <span class="text-sm font-bold text-primary uppercase tracking-wider">MAXIMUM MARGIN</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-foreground mb-6">TIER 2 - SELL PACKAGES, KEEP 35-50%</h3>

            <div class="mb-6">
              <h4 class="font-bold text-foreground mb-3">THE MODEL:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>Sell &ldquo;copy + design&rdquo; to the client as a single package</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>Buy design from us at partner price (-35% off list)</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>You manage client and decide final price</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>We work behind the scenes (white label)</li>
              </ul>
            </div>

            <div class="mb-6">
              <h4 class="font-bold text-foreground mb-3">THE CLIENT THINKS THAT:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>You have an internal team</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>You did everything yourself</li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground"><span class="text-gold">&bull;</span>You&rsquo;re a complete agency</li>
              </ul>
            </div>

            <div class="bg-gold/5 rounded-lg p-4 mb-6">
              <h4 class="font-bold text-foreground mb-3">PRACTICAL EXAMPLE:</h4>
              <p class="text-sm text-muted-foreground mb-3">Client wants complete sales page</p>
              <ul class="space-y-1 mb-3">
                <li class="text-sm text-muted-foreground">You sell to client: &euro;4,000 total</li>
                <li class="text-sm text-muted-foreground">&nbsp;&nbsp;&bull; Copy: &euro;2,000 (your work)</li>
                <li class="text-sm text-muted-foreground">&nbsp;&nbsp;&bull; Design: &euro;2,000 (resale)</li>
                <li class="text-sm text-muted-foreground">You buy design from us: &euro;1,300 (partner price)</li>
                <li class="text-sm text-muted-foreground">Design margin: &euro;700</li>
                <li class="text-sm text-muted-foreground">Copy margin: &euro;2,000</li>
                <li class="text-sm text-muted-foreground">&rarr; TOTAL EARNINGS: &euro;2,700 (vs &euro;2,000 copy only)</li>
              </ul>
              <p class="text-sm font-semibold text-foreground mb-2">With 2 packages/month:</p>
              <ul class="space-y-1 mb-3">
                <li class="text-sm text-muted-foreground">Extra design margin: &euro;1,400-2,000/month</li>
                <li class="text-sm text-muted-foreground">Copy income: &euro;4,000-6,000/month</li>
              </ul>
              <p class="text-sm font-bold text-gold">MONTHLY TOTAL: &euro;5,400-8,000</p>
              <p class="text-sm font-bold text-gold">YEARLY EXTRA (design margins only): &euro;16,800-24,000</p>
            </div>

            <div>
              <h4 class="font-bold text-foreground mb-3">PERFECT IF:</h4>
              <ul class="space-y-2">
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You want to sell complete service
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You have recurring or high-budget clients
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You want &ldquo;premium agency&rdquo; positioning
                </li>
                <li class="flex items-start gap-2 text-sm text-muted-foreground">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  You&rsquo;re ok managing client communication
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-background border border-gold/20 rounded-xl p-6 text-center max-w-3xl mx-auto mb-8">
        <p class="text-foreground">&#128161; You can use both models: Tier 1 for small clients, Tier 2 for big ones. Or start with Tier 1 and switch to Tier 2 when you&rsquo;re ready. No obligations, no mandatory contract.</p>
      </div>

      <div class="text-center">
