---
import Layout from "../layouts/Layout.astro";
import { localPath } from "../lib/i18n";
import founderImage from "../assets/davide-founder.webp";
import claudeHopkins from "../assets/masters/claude-hopkins.webp";
import davidOgilvy from "../assets/masters/david-ogilvy.webp";
import garyHalbert from "../assets/masters/gary-halbert.webp";

const lang = "en";
const whatsappUrl = `https://wa.me/3550695822380?text=${encodeURIComponent("Hello, I'd like to talk about your design services")}`;
---

<Layout
  title="About Us | Keryx Design - Direct Response Design Studio"
  description="Discover who we are, our method, and why Direct Response Design is different from traditional graphic design. Science, strategy, and AI at the service of conversions."
  lang={lang}
>
  <!-- ============================================= -->
  <!-- SECTION 1: HERO                               -->
  <!-- ============================================= -->
  <section class="relative min-h-[70vh] flex items-center bg-marble">
    <div class="container mx-auto px-4 py-16 lg:py-24">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white/90 backdrop-blur-sm rounded-2xl shadow-xl p-8 md:p-12 lg:p-16 text-center">
          <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-[56px] leading-[1.1] mb-6 text-foreground">
            Traditional designers create art.<br />
            <span class="text-primary">We create salesmen on paper.</span>
          </h1>
          <p class="text-lg md:text-xl font-semibold text-primary mb-4">
            Illegible fonts. Inverted hierarchies. Hidden calls-to-action.
          </p>
          <p class="text-base md:text-lg text-muted-foreground leading-relaxed max-w-3xl mx-auto mb-4">
            Every day, brilliant copy gets sabotaged by &ldquo;creative&rdquo; design that puts aesthetics before readability. The message gets lost. Conversions plummet.
          </p>
          <p class="text-base md:text-lg text-foreground font-semibold max-w-3xl mx-auto">
            We&rsquo;re not graphic designers. We&rsquo;re <em>Direct Response Designers</em>. And the difference shows in the results.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 2: PHILOSOPHY                         -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32 bg-navy">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto text-center">
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mb-6 text-primary-foreground">
          Direct Response Design: Not Art, Science
        </h2>

        <!-- Masters photos -->
        <div class="flex justify-center gap-8 md:gap-12 mb-10">
          <div class="flex flex-col items-center">
            <img
              src={claudeHopkins.src}
              alt="Claude Hopkins"
              class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-3 border-gold shadow-lg"
            />
            <span class="text-primary-foreground/80 text-sm mt-2">Claude Hopkins</span>
          </div>
          <div class="flex flex-col items-center">
            <img
              src={davidOgilvy.src}
              alt="David Ogilvy"
              class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-3 border-gold shadow-lg"
            />
            <span class="text-primary-foreground/80 text-sm mt-2">David Ogilvy</span>
          </div>
          <div class="flex flex-col items-center">
            <img
              src={garyHalbert.src}
              alt="Gary Halbert"
              class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-3 border-gold shadow-lg"
            />
            <span class="text-primary-foreground/80 text-sm mt-2">Gary Halbert</span>
          </div>
        </div>

        <div class="max-w-3xl mx-auto text-left space-y-4">
          <p class="text-lg text-primary-foreground/90 leading-relaxed">
            Direct Response Design has existed for over 100 years. <strong class="text-primary-foreground">Claude Hopkins</strong>. <strong class="text-primary-foreground">David Ogilvy</strong>. <strong class="text-primary-foreground">Gary Halbert</strong>. They sold billions using scientific principles of readability, visual persuasion, and neuroscience.
          </p>
          <p class="text-lg text-primary-foreground/90 leading-relaxed">
            It&rsquo;s not about &ldquo;what the designer likes.&rdquo; It&rsquo;s about what makes the reader <strong class="text-primary-foreground">read</strong>, <strong class="text-primary-foreground">understand</strong>, and <strong class="text-primary-foreground">act</strong>.
          </p>
          <p class="text-lg text-primary-foreground/90 leading-relaxed">
            Every choice &mdash; typography, spacing, contrast, hierarchy &mdash; has a scientific rationale. And a measurable result.
          </p>
          <p class="text-xl text-gold font-semibold mt-6">
            Creative design wins awards. Direct Response Design sells. We do the latter.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 3: METHOD                             -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32" style="background: linear-gradient(180deg, hsl(40 30% 96%) 0%, hsl(40 25% 92%) 100%);">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mb-4 text-foreground">
          The Keryx Method: Science + Strategy + AI
        </h2>
        <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto">
          100 years of foundations. 2025 tools. Zero compromises on quality.
        </p>
      </div>

      <!-- 3 Pillar Cards -->
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto mb-20">
        <!-- Pillar 1 -->
        <div class="bg-card border border-border rounded-xl p-8 shadow-card hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <!-- Brain icon -->
            <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a7 7 0 0 0-7 7c0 3 2 5 3 7h8c1-2 3-4 3-7a7 7 0 0 0-7-7Z"/>
              <path d="M9 22h6"/>
              <path d="M9 18h6"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-foreground mb-3">Readability Neuroscience</h3>
          <p class="text-muted-foreground leading-relaxed mb-4">
            Eye-tracking, F-pattern, Z-pattern, Gestalt principles applied to layout. Every element is placed where the brain expects to find it.
          </p>
          <p class="text-sm text-gold font-semibold">
            Payoff: the reader reads everything, effortlessly.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div class="bg-card border border-border rounded-xl p-8 shadow-card hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <!-- Layers icon -->
            <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
              <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/>
              <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-foreground mb-3">Print + Digital Integrated</h3>
          <p class="text-muted-foreground leading-relaxed mb-4">
            Sales letters, magalogs, landing pages, emails, ads &mdash; all with the same DR principles. Your funnel is consistent from first touch to last click.
          </p>
          <p class="text-sm text-gold font-semibold">
            Payoff: consistency = trust = conversion.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div class="bg-card border border-border rounded-xl p-8 shadow-card hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-5">
            <!-- Cpu icon (AI) -->
            <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <rect x="9" y="9" width="6" height="6"/>
              <path d="M15 2v2"/>
              <path d="M15 20v2"/>
              <path d="M2 15h2"/>
              <path d="M2 9h2"/>
              <path d="M20 15h2"/>
              <path d="M20 9h2"/>
              <path d="M9 2v2"/>
              <path d="M9 20v2"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-foreground mb-3">Human + AI</h3>
          <p class="text-muted-foreground leading-relaxed mb-4">
            We use AI to speed up research, variants, and testing. But every strategic and creative decision is human. AI is an amplifier, not a replacement.
          </p>
          <p class="text-sm text-gold font-semibold">
            Payoff: 10x speed, unchanged quality.
          </p>
        </div>
      </div>

      <!-- Process Steps -->
      <div class="max-w-4xl mx-auto">
        <h3 class="font-display text-2xl md:text-3xl text-center mb-10 text-foreground">Our Process</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { step: "1", title: "Strategy call", desc: "We analyze your business, funnel, and objectives. Free, no commitment." },
            { step: "2", title: "Custom proposal", desc: "You receive a detailed plan with timelines, deliverables, and investment." },
            { step: "3", title: "Collaborative execution", desc: "We design, you review. Structured feedback rounds until approval." },
            { step: "4", title: "Delivery + follow-up", desc: "Print-ready or web-ready files. Post-delivery support included." },
          ].map((item) => (
            <div class="bg-white border border-border rounded-lg p-6 text-center shadow-sm">
              <div class="w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center mx-auto mb-4 font-bold text-lg">
                {item.step}
              </div>
              <h4 class="font-display text-lg text-foreground mb-2">{item.title}</h4>
              <p class="text-sm text-muted-foreground">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 4: TRACK RECORD                       -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32 bg-primary">
    <div class="container mx-auto px-4">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-center mb-16 text-primary-foreground">
        Results That Speak
      </h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Block 1: Chief Design Officer -->
        <div class="bg-primary-foreground/10 border border-primary-foreground/20 rounded-xl p-8">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mb-5">
            <!-- Briefcase icon -->
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
          </div>
          <h3 class="font-display text-2xl text-primary-foreground mb-4">Chief Design Officer</h3>
          <p class="text-primary-foreground/80 leading-relaxed mb-4">
            3 years leading the graphics department at <strong class="text-primary-foreground">Metodo Merenda</strong>, the largest direct marketing company in Italy.
          </p>
          <p class="text-primary-foreground/80 leading-relaxed">
            Hundreds of campaigns. Dozens of clients. Millions in traceable revenue generated.
          </p>
        </div>

        <!-- Block 2: Trained by Lori Haller -->
        <div class="bg-primary-foreground/10 border border-primary-foreground/20 rounded-xl p-8">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mb-5">
            <!-- Award icon -->
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
          </div>
          <h3 class="font-display text-2xl text-primary-foreground mb-4">Trained by Lori Haller</h3>
          <p class="text-primary-foreground/80 leading-relaxed mb-4">
            First Italian designer trained directly by <strong class="text-primary-foreground">Lori Haller</strong>, the most famous Direct Response Designer in the United States.
          </p>
          <p class="text-primary-foreground/80 leading-relaxed">
            Classic American methodology applied to the Italian and European market.
          </p>
        </div>

        <!-- Block 3: The Numbers -->
        <div class="bg-primary-foreground/10 border border-primary-foreground/20 rounded-xl p-8">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mb-5">
            <!-- TrendingUp icon -->
            <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <h3 class="font-display text-2xl text-primary-foreground mb-4">The Numbers</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 font-bold">+</span>
              <span class="text-primary-foreground/90">500+ direct response materials designed</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 font-bold">+</span>
              <span class="text-primary-foreground/90">50+ businesses served in Italy and abroad</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-gold mt-1 font-bold">+</span>
              <span class="text-primary-foreground/90">100% focus on direct response (zero pure branding)</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 5: PRINCIPLES                         -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32 bg-marble">
    <div class="container mx-auto px-4">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-center mb-16 text-foreground">
        Our Principles
      </h2>

      <!-- 4 Principle Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto mb-16">
        <!-- Total Transparency -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-card">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4">
            <!-- Eye icon -->
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7Z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-foreground mb-2">Total Transparency</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Every design choice is explained and justified. No &ldquo;trust me, I&rsquo;m the creative.&rdquo; You know exactly why every element is where it is.
          </p>
        </div>

        <!-- Results > Aesthetics -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-card">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4">
            <!-- Target icon -->
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-foreground mb-2">Results &gt; Aesthetics</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            An &ldquo;ugly&rdquo; piece that converts is worth 100 times a &ldquo;beautiful&rdquo; piece that doesn&rsquo;t sell. We always aim for numbers, never for awards.
          </p>
        </div>

        <!-- Collaboration Not Ego -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-card">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4">
            <!-- Users icon -->
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-foreground mb-2">Collaboration Not Ego</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Your copy is sacred. We never modify it. Our job is to amplify it, not overwrite it. The designer serves the message, not the other way around.
          </p>
        </div>

        <!-- Selectivity -->
        <div class="bg-card border border-border rounded-xl p-6 shadow-card">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4">
            <!-- Shield icon -->
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
            </svg>
          </div>
          <h3 class="font-display text-lg text-foreground mb-2">Selectivity</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            We don&rsquo;t work with everyone. We only accept projects where we can truly make a difference. If we&rsquo;re not the right fit, we&rsquo;ll tell you upfront.
          </p>
        </div>
      </div>

      <!-- Don't Do Red Box -->
      <div class="max-w-3xl mx-auto">
        <div class="bg-red-50 border-2 border-red-200 rounded-xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <!-- X circle icon -->
            <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="m15 9-6 6"/>
              <path d="m9 9 6 6"/>
            </svg>
            <h3 class="font-display text-xl text-red-700">What We Don&rsquo;t Do</h3>
          </div>
          <ul class="space-y-3">
            {[
              "Pure branding (logos, brand identity without a sales objective)",
              "\"Creative\" design for its own sake",
              "Work without written copy (text first, then layout)",
              "Projects where the designer decides what to write",
              "Clients who want to \"look professional\" without measuring results",
              "Blind quotes without a strategy call",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-red-400 mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
                <span class="text-red-700/90">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 6: FOUNDER                            -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32" style="background: linear-gradient(180deg, hsl(40 30% 96%) 0%, hsl(0 0% 100%) 100%);">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
          <!-- Photo -->
          <div class="flex flex-col items-center lg:items-end">
            <img
              src={founderImage.src}
              alt="Davide Filippini - Founder of Keryx Design"
              class="rounded-2xl shadow-xl max-w-sm w-full object-cover"
            />
            <p class="mt-4 text-base text-muted-foreground italic text-center">
              Davide &ldquo;Dave&rdquo; Filippini &mdash; Founder of Keryx Design
            </p>
          </div>

          <!-- Bio -->
          <div>
            <h2 class="font-display text-3xl md:text-4xl text-foreground mb-6">
              The Founder: Davide Filippini
            </h2>
            <div class="space-y-4 text-muted-foreground leading-relaxed">
              <p>
                Davide started as a &ldquo;traditional&rdquo; graphic designer. Creative portfolio, awards, visually stunning projects. Then came the turning point: he joined as <strong class="text-foreground">Chief Design Officer at Metodo Merenda</strong>, the largest direct marketing company in Italy.
              </p>
              <p>
                There he discovered a completely different world. Materials don&rsquo;t have to &ldquo;look pretty&rdquo; &mdash; they have to <strong class="text-foreground">sell</strong>. Every font, every margin, every color has a measurable impact on response rates. Aesthetics serve conversion, not the other way around.
              </p>

              <!-- Turning Point -->
              <div class="bg-gold-bg border-l-4 border-gold p-6 rounded-r-lg my-6">
                <h4 class="font-display text-lg text-foreground mb-2">The Turning Point</h4>
                <p class="text-muted-foreground">
                  After 3 years and hundreds of campaigns, Davide trained directly under <strong class="text-foreground">Lori Haller</strong> &mdash; the most famous Direct Response Designer in the United States. He became her first Italian student. From that moment, the mission was clear: bring true Direct Response Design to Italy and Europe.
                </p>
              </div>

              <!-- Philosophy -->
              <div class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg">
                <h4 class="font-display text-lg text-foreground mb-2">The Philosophy</h4>
                <p class="text-muted-foreground">
                  &ldquo;There&rsquo;s no beautiful or ugly design. There&rsquo;s design that sells and design that doesn&rsquo;t. My job is to make sure yours belongs to the first category.&rdquo;
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- SECTION 7: FINAL CTA                          -->
  <!-- ============================================= -->
  <section class="py-20 lg:py-32 bg-primary">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mb-6 text-primary-foreground">
          Ready to Work Together?
        </h2>
        <p class="text-lg text-primary-foreground/80 mb-8">
          We don&rsquo;t work with everyone. Here are the criteria to work with us:
        </p>

        <!-- Criteria List -->
        <div class="text-left max-w-xl mx-auto mb-10">
          <ul class="space-y-3">
            {[
              "You have written copy (or a copywriter who will write it)",
              "You want measurable results, not just to \"look professional\"",
              "You're willing to invest in design that converts",
              "You respect the process: strategy call \u2192 proposal \u2192 execution",
            ].map((criterion) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-primary-foreground/90">{criterion}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA Button -->
        <div class="mb-12">
          <a
            href={localPath("/audit", lang)}
