---
import Layout from "../../layouts/Layout.astro";
import { localPath } from "../../lib/i18n";
import FAQAccordion from "../../components/react/FAQAccordion";
import TestimonialsCarousel from "../../components/react/TestimonialsCarousel";
import CaseStudiesCarousel from "../../components/react/CaseStudiesCarousel";
import { getTestimonials } from "../../content/testimonials";
import { getCaseStudies } from "../../content/caseStudies";
import davideFounder from "../../assets/davide-founder.webp";

const lang = "it";

const whatsappUrl = `https://wa.me/393387445057?text=${encodeURIComponent("Ciao Davide posso vedere i siti che hai fatto?")}`;

const testimonials = getTestimonials(lang);
const serializedTestimonials = testimonials.map((t) => ({
  quote: t.quote,
  author: t.author,
  role: t.role,
  imageSrc: t.image.src,
}));

const caseStudies = getCaseStudies(lang);
const serializedCases = caseStudies.map((c) => ({
  slug: c.slug,
  thumbnailSrc: c.thumbnail.src,
}));
const basePath = localPath("/blog/case-studies", lang);

const faqs = [
  {
    question: "E se dopo voglio cambiare qualcosa?",
    answer: "Nessun problema. Ogni modifica dopo la consegna costa €50 a intervento. Mi scrivi, mi dici cosa cambiare, e lo faccio.",
  },
  {
    question: "Devo comprare il dominio?",
    answer: "No. Il dominio (cioè il nome del tuo sito, tipo www.tuonome.it) lo compro io per te. L'unica cosa che devi fare è rinnovarlo ogni anno — costa pochi euro.",
  },
  {
    question: "Cos'è l'hosting?",
    answer: "L'hosting è lo \"spazio\" su internet dove sta il tuo sito. Ci penso io, è incluso nel prezzo. Non devi fare niente.",
  },
  {
    question: "E se non mi piace il risultato?",
    answer: "Ti ridò tutti i soldi. 100%. Nessuna domanda. Ma in 10 anni non è mai successo.",
  },
  {
    question: "Quanto ci vuole davvero?",
    answer: "5 giorni. Ma funziona solo se anche tu rispondi veloce. Se mi mandi le info dopo 2 settimane, i 5 giorni diventano 5 settimane.",
  },
  {
    question: "Solo una pagina? Non mi servono più pagine?",
    answer: "Una pagina fatta bene vale più di un sito con 47 pagine che nessuno legge. Una pagina. Chiara. Bella. Che porta clienti. È tutto quello che ti serve.",
  },
  {
    question: "Ma il sito sarà bello?",
    answer: "Bellissimo. Garantito. Ma la differenza è che non sarà solo bello — sarà fatto per portarti clienti.",
  },
];
---

<Layout
  title="Sito web professionale in 5 giorni — €297 tutto incluso | Keryx Design"
  description="Se non hai un sito, non esisti. Ti faccio un sito bellissimo che lavora per te. Una pagina. 5 giorni. €297 tutto incluso. Solo 3 posti."
  lang={lang}
  showHeader={false}
  showFooter={false}
>
  <!-- TOP BAR -->
  <div class="fixed top-0 left-0 right-0 z-40 bg-coral text-white text-center py-2 text-sm font-medium tracking-wide">
    ⚠️ Solo <strong>3 posti</strong> a questo prezzo. Poi torna a €500.
  </div>

  <div class="pt-9">

    <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
    <section class="relative min-h-[80vh] flex items-center bg-marble">
      <div class="absolute inset-0 bg-cream/85"></div>
      <div class="relative container max-w-3xl mx-auto px-6 py-16 md:py-24 text-center">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-5">Keryx Design</p>
        <img
          src={davideFounder.src}
          alt="Davide Filippini — Web Designer"
          class="w-24 h-24 rounded-full object-cover mx-auto mb-7 shadow-xl" style="outline: 3px solid rgba(240,180,40,0.4); outline-offset: 5px;"
          loading="eager"
        />
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-navy tracking-tight leading-[1.1] mb-6">
          Se non hai un sito, non esisti.
        </h1>
        <p class="text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto mb-3 leading-relaxed">
          Era vero dieci anni fa. Nell'era dell'intelligenza artificiale, lo è ancora di più.
        </p>
        <p class="text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto mb-10 leading-relaxed">
          Ti faccio un sito bellissimo che lavora per te. Una pagina. 5 giorni. <span class="line-through text-foreground/40">€500</span> <strong class="text-navy text-2xl">€297</strong>. Tutto incluso.
        </p>

        <div class="bg-coral/10 border border-coral/20 rounded-lg px-4 py-3 mb-8 max-w-lg mx-auto flex items-start gap-2">
          <span class="text-coral shrink-0 mt-0.5">⚠️</span>
          <p class="text-sm text-foreground/80 leading-relaxed">
            Solo <strong class="text-navy">3 posti</strong> a questo prezzo. Poi torna a €500.
          </p>
        </div>

        <div class="flex justify-center">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 bg-[#25D366] hover:bg-[#128C7E] text-white font-bold px-8 py-4 rounded-xl shadow-lg transition-all hover:shadow-xl hover:-translate-y-0.5 group" style="font-size:1.05rem;"
          >
            <svg viewBox="0 0 24 24" class="fill-current shrink-0" style="width:22px;height:22px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Mandami i siti d'esempio
            <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
        <p class="mt-3 text-sm text-foreground/50 max-w-md mx-auto leading-relaxed">
          Ti mando subito qualche esempio su WhatsApp. Zero impegno.
        </p>
      </div>
    </section>

    <!-- ═══ SOCIAL PROOF SUBITO DOPO HERO ════════════════════════════════════ -->
    <section class="bg-navy py-12 md:py-16">
      <div class="container max-w-4xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">Cosa dicono i miei clienti</p>
        <TestimonialsCarousel
          client:visible
          testimonials={serializedTestimonials}
          variant="dark"
        />
      </div>
    </section>

    <!-- ═══ IL PROBLEMA ════════════════════════════════════════════════════════ -->
    <section class="bg-background py-16 md:py-22">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">Il problema</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10">
          La gente non cerca più come una volta. Cerca meglio.
        </h2>
        <div class="space-y-5 text-lg text-foreground/80 leading-relaxed">
          <p>Nel 2026 i tuoi clienti cercano tutto online. Il ristorante, l'idraulico, il dentista, il commercialista.</p>

          <p>Ma non è più solo Google. Oggi le persone chiedono direttamente <strong class="text-navy">all'intelligenza artificiale</strong>: <em>"Trovami un idraulico a Trento."</em> <em>"Qual è il miglior ristorante per una cena di lavoro a Milano?"</em></p>

          <p>L'AI non inventa le risposte. Le prende dai siti. Se il tuo sito non c'è — o è fatto male — <mark class="bg-gold/30 text-navy px-1 rounded">l'intelligenza artificiale non ti consiglia a nessuno.</mark></p>

          <p>Non è una questione di tecnologia. È una questione di visibilità: <strong class="text-navy">se non ti trovano, per i tuoi clienti non esisti.</strong></p>
        </div>
      </div>
    </section>

    <!-- ═══ L'OBIEZIONE ══════════════════════════════════════════════════════ -->
    <section class="bg-cream py-16 md:py-22">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">L'obiezione</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10">
          "Ma io lavoro col passaparola."
        </h2>
        <div class="space-y-5 text-lg text-foreground/80 leading-relaxed">
          <p>Benissimo. E quando quel passaparola ti cerca online per conferma — <strong class="text-navy">cosa trova?</strong></p>

          <p>Niente. Oppure un sito vecchio di dieci anni che sembra una pagina di Pagine Gialle.</p>

          <p>Il risultato è sempre lo stesso: <strong class="text-navy">il cliente va da un altro.</strong> Da uno che ha un sito fatto bene. Anche se è peggio di te.</p>
        </div>
      </div>
    </section>

    <!-- ═══ IL SITO CHE LAVORA ═══════════════════════════════════════════════ -->
    <section class="bg-background py-16 md:py-22">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">Il sito che lavora</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10">
          Un sito fatto bene è un dipendente che non dorme mai.
        </h2>
        <div class="space-y-5 text-lg text-foreground/80 leading-relaxed">
          <ul class="space-y-4">
            {[
              "Alle 11 di sera qualcuno vuole prenotare un appuntamento — il sito raccoglie il contatto mentre tu dormi.",
              "Il sabato mattina un potenziale cliente ti cerca su Google — ti trova, capisce cosa fai, ti contatta.",
              "Dopo una fiera qualcuno si ricorda di te ma non del tuo numero — ti cerca online e prenota.",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-foreground/80 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

          <div class="p-6 bg-cream rounded-lg border-l-4 border-navy mt-8">
            <p class="text-lg leading-relaxed text-navy font-medium">
              Senza un sito, tutti questi clienti li stai <strong>lasciando ad altri.</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ IL VERO PROBLEMA ═════════════════════════════════════════════════ -->
    <section class="bg-cream py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">Il vero problema</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10">
          Il problema non è non avere un sito. È averne uno che non funziona.
        </h2>
        <div class="space-y-5 text-lg text-foreground/80 leading-relaxed">
          <p class="italic text-navy text-xl">"Ok, ma il sito ce l'ho."</p>

          <p>Apriamolo insieme. Probabilmente:</p>

          <ul class="space-y-3">
            {[
              "Ci mette una vita a caricarsi — e metà dei visitatori se ne va prima di vederlo",
              "Non si capisce cosa fai nei primi 3 secondi",
              "Non c'è un modo semplice per contattarti",
              "Da telefono è illeggibile — e oggi quasi tutti navigano dal cellulare",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-coral shrink-0 mt-0.5">✗</span>
                <span class="text-foreground/80 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

          <p>Il tuo web designer l'ha fatto "bello". <strong class="text-navy">Ma bello non porta clienti.</strong></p>

          <p>I siti alla vecchia maniera — quelli da 3.000€, sei mesi di sviluppo, 47 pagine che nessuno legge — <mark class="bg-gold/30 text-navy px-1 rounded">non hanno più senso.</mark></p>
        </div>
      </div>
    </section>

    <!-- ═══ COME LI FACCIO IO ═════════════════════════════════════════════════ -->
    <section class="bg-navy text-primary-foreground py-16 md:py-20">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">Il mio approccio</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold mb-8">Come li faccio io.</h2>
        <div class="space-y-5 text-lg text-primary-foreground/85 leading-relaxed">
          <p>Uso l'intelligenza artificiale per costruire siti in modo veloce e a una <strong class="text-primary-foreground">frazione del costo</strong>.</p>

          <p>Ma l'AI da sola non basta. Senza esperienza, produce siti belli e inutili. Esattamente come un web designer tradizionale.</p>

          <p><strong class="text-primary-foreground">La differenza è quello che ci metto sopra:</strong></p>

          <ul class="space-y-4 mt-4">
            {[
              { bold: "10 anni di marketing", rest: " — so cosa fa vendere e cosa no" },
              { bold: "Il testo lo scrivo io", rest: " — le parole sul tuo sito non sono riempitivi, sono fatte per portarti clienti" },
              { bold: "Ogni pezzo del sito ha un obiettivo", rest: " — niente decorazione, tutto guida il visitatore a contattarti" },
              { bold: "Il sito è bellissimo", rest: " — perché un sito che funziona deve anche fare una bella figura" },
              { bold: "Pronto per l'intelligenza artificiale", rest: " — i miei siti sono costruiti perché ChatGPT, Gemini e le altre AI ti trovino e ti consiglino. La maggior parte dei siti là fuori non lo sono." },
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-primary-foreground/85 leading-relaxed"><strong class="text-primary-foreground">{item.bold}</strong>{item.rest}</span>
              </li>
            ))}
          </ul>

          <div class="p-6 bg-white/10 rounded-lg border-l-4 border-gold mt-8">
            <p class="text-lg font-medium text-primary-foreground leading-relaxed">
              Il risultato: un sito che costa come un pranzo aziendale ma <strong>lavora come un commerciale a tempo pieno.</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CHI SONO ════════════════════════════════════════════════════════════ -->
    <section class="bg-background py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3">Chi sono</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10">
          Da commesso a 17 anni al mercato americano.
        </h2>

        <div class="md:flex gap-10 items-start mb-10">
          <div class="flex-shrink-0 mb-8 md:mb-0">
            <img
              src={davideFounder.src}
              alt="Davide Filippini — Web Designer"
              class="w-48 h-48 md:w-56 md:h-56 rounded-xl object-cover mx-auto shadow-xl" style="outline: 2px solid rgba(240,180,40,0.25); outline-offset: 3px;"
              loading="lazy"
            />
            <p class="mt-3 text-sm text-muted-foreground text-center italic">Davide Filippini</p>
          </div>
          <div class="space-y-4 text-lg text-foreground/80 leading-relaxed">
            <p>Mi chiamo Davide. A 17 anni lavoravo in un negozio di abbigliamento e già mi occupavo di grafica e marketing.</p>
            <p>Ho studiato grafica. Ma mi sono accorto subito che le imprese non hanno bisogno di roba carina — <mark class="bg-gold/30 text-navy px-1 rounded"><strong class="text-navy">hanno bisogno di vendere di più.</strong></mark></p>
            <p>Così ho studiato copywriting alla scuola più importante d'Italia all'epoca.</p>
            <p>Ma guardando i materiali americani ho notato una cosa: la grafica non era "creativa" nel senso classico. Era orientata alla leggibilità. Quasi invisibile. Eppure funzionava.</p>
            <p>Quella grafica aveva un nome. <strong class="text-navy">L'ho studiata a fondo, fino a trovare chi l'aveva portata ai massimi livelli negli Stati Uniti. È diventata la mia maestra.</strong></p>
          </div>
        </div>

        <div class="space-y-4 text-lg text-foreground/80 leading-relaxed">
          <p>Ho aperto <mark class="bg-gold/30 text-navy px-1 rounded">il primo sito italiano</mark> dedicato a questa disciplina.</p>
          <p>Poco dopo, <strong class="text-navy">la più grande azienda di formazione marketing in Italia</strong> mi ha chiamato per gestire il suo reparto grafico. <strong class="text-navy">3 anni.</strong> Un flusso enorme di lavori. Scadenze "per ieri", ogni giorno. Team di designer da capitanare. <strong class="text-navy">Ogni pezzo doveva portare risultati misurabili.</strong></p>
          <p>Dopo quell'esperienza ho fondato <strong class="text-navy">Keryx Design</strong> e ho iniziato a lavorare direttamente con il mercato americano.</p>
          <p>Nel 2026 ho aggiunto l'intelligenza artificiale al mio flusso di lavoro. Non per sostituire gusto ed esperienza — <strong class="text-navy">quelli l'AI non ce li ha</strong> — ma per <mark class="bg-gold/30 text-navy px-1 rounded">moltiplicare la velocità.</mark></p>

          <div class="p-6 bg-cream rounded-lg border-l-4 border-gold mt-6">
            <p class="text-lg font-medium text-navy leading-relaxed">
              Il risultato: la qualità di un designer senior, l'esperienza di centinaia di progetti, la velocità di chi ha integrato l'AI nel proprio processo.<br />
              <em>A un prezzo che fino a un anno fa sarebbe stato impossibile.</em>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ RISULTATI / CASI STUDIO ══════════════════════════════════════════ -->
    <section class="bg-cream py-20 md:py-28">
      <div class="container max-w-4xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">I risultati dei miei clienti</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-10 text-center">
          Non teoria — fatturato.
        </h2>

        <CaseStudiesCarousel
          client:visible
          cases={serializedCases}
          basePath={basePath}
          clickable={false}
        />
      </div>
    </section>

    <!-- ═══ TESTIMONIANZE ══════════════════════════════════════════════════════ -->
    <section class="bg-navy py-20 md:py-28">
      <div class="container max-w-4xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">Cosa dicono i miei clienti</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-primary-foreground tracking-tight mb-12 text-center">
          Non lo dico solo io.
        </h2>
        <TestimonialsCarousel
          client:visible
          testimonials={serializedTestimonials}
          variant="dark"
        />
      </div>
    </section>

    <!-- ═══ COME FUNZIONA ══════════════════════════════════════════════════════ -->
    <section class="bg-cream py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">Come funziona</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-12 text-center">
          5 giorni. Zero complicazioni.
        </h2>
        <div class="space-y-10">
          <!-- Giorno 1 -->
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">1</div>
            <div>
              <h3 class="font-display text-xl font-bold text-navy mb-2">Giorno 1: Ci sentiamo</h3>
              <p class="text-foreground/70 leading-relaxed">Chiamata di 20 minuti. Mi racconti cosa fai e chi sono i tuoi clienti. Ti mando una lista con quello che mi serve. <strong class="text-navy">Niente di complicato.</strong></p>
            </div>
          </div>
          <!-- Giorno 2-3 -->
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">2</div>
            <div>
              <h3 class="font-display text-xl font-bold text-navy mb-2">Giorno 2-3: Io scrivo e costruisco</h3>
              <p class="text-foreground/70 leading-relaxed"><strong class="text-navy">Il testo lo scrivo io. Il sito lo faccio io.</strong> Tu non devi fare niente. Ricevi la bozza e un giro di modifiche.</p>
            </div>
          </div>
          <!-- Giorno 4-5 -->
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">3</div>
            <div>
              <h3 class="font-display text-xl font-bold text-navy mb-2">Giorno 4-5: Revisione e via</h3>
              <p class="text-foreground/70 leading-relaxed">Applico le modifiche, controllo che sia perfetto da telefono e da computer. <mark class="bg-gold/30 text-navy px-1 rounded">Il sito va online. Pronto a lavorare per te.</mark></p>
            </div>
          </div>
        </div>

        <div class="bg-coral/10 border border-coral/20 rounded-lg px-5 py-4 mt-10 flex items-start gap-2">
