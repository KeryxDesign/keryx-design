---
import Layout from "../../layouts/Layout.astro";

const lang = "it";
---

<Layout
  title="Cos'è il DRD | Keryx Design"
  description="Scopri cos'è il Direct Response Design e come può aiutare il tuo business."
  lang={lang}
>
  <section class="bg-marble py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] mb-8 text-foreground">
          Cos&rsquo;&egrave; il DRD
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
          Contenuto in arrivo...
        </p>
      </div>
    </div>
  </section>
</Layout>
