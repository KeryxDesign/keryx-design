---
import Layout from "../../layouts/Layout.astro";
import { localPath } from "../../lib/i18n";
import TestimonialsCarousel from "../../components/react/TestimonialsCarousel";
import CaseStudiesCarousel from "../../components/react/CaseStudiesCarousel";
import { getTestimonials } from "../../content/testimonials";
import { getCaseStudies } from "../../content/caseStudies";
import davideFounder from "../../assets/davide-founder.webp";

const lang = "it";

const whatsappUrl = `https://wa.me/393387445057?text=${encodeURIComponent("Ciao Davide posso vedere i siti che hai fatto?")}`;

const testimonials = getTestimonials(lang);
const serializedTestimonials = testimonials.map((t) => ({
  quote: t.quote,
  author: t.author,
  role: t.role,
  imageSrc: t.image.src,
}));

const caseStudies = getCaseStudies(lang);
const serializedCases = caseStudies.map((c) => ({
  slug: c.slug,
  thumbnailSrc: c.thumbnail.src,
}));
const basePath = localPath("/blog/case-studies", lang);
---

<Layout
  title="Ti faccio il sito — 297€ tutto compreso | Keryx Design"
  description="Sito web professionale a 297€. Pronto in 5 giorni. Garanzia soddisfatto o rimborsato. Scrivimi su WhatsApp."
  lang="it"
  showHeader={false}
  showFooter={false}
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
  <section class="bg-cream min-h-[70vh] flex items-center justify-center" style="padding:3rem 1.5rem;">
    <div style="max-width:600px;margin:0 auto;text-align:center;">

      <h1 style="font-size:clamp(2.5rem,8vw,3.5rem);font-weight:800;line-height:1.15;color:hsl(204,96%,10%);margin:0 0 0.75rem;">
        Ti faccio il sito.<br>
        <span style="color:hsl(38,90%,33%);">297 euro.</span>
      </h1>

      <p style="font-size:clamp(1.25rem,4vw,1.5rem);line-height:1.5;color:hsl(204,96%,10%);opacity:0.85;margin:0 0 2rem;">
        Tutto compreso. Pronto in 5 giorni.
      </p>

      <!-- CTA WhatsApp -->
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="display:block;background:#198844;color:#fff;font-size:1.25rem;font-weight:700;padding:1.1rem 2rem;border-radius:1rem;text-decoration:none;text-align:center;max-width:400px;margin:0 auto 1.5rem;box-shadow:0 4px 14px rgba(25,136,68,0.4);transition:transform 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(25,136,68,0.5)'"
        onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 14px rgba(25,136,68,0.4)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:24px;height:24px;display:inline-block;vertical-align:middle;margin-right:8px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Mandami i siti d'esempio
      </a>

      <!-- Trust line -->
      <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;">
        <img
          src={davideFounder.src}
          alt="Davide Filippini"
          style="width:44px;height:44px;border-radius:50%;object-fit:cover;"
          loading="eager"
        />
        <p style="font-size:1rem;color:hsl(204,96%,10%);opacity:0.78;margin:0;">
          Ti rispondo io, Davide. Niente call center.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══ SOCIAL PROOF ════════════════════════════════════════════════════── -->
  <section class="bg-navy" style="padding:3rem 1.5rem;">
    <div style="max-width:600px;margin:0 auto;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:hsl(42,87%,55%);text-align:center;margin:0 0 1rem;">
        Cosa dicono i miei clienti
      </p>
      <TestimonialsCarousel client:visible testimonials={serializedTestimonials} variant="dark" />
    </div>
  </section>


  <!-- ═══ IL PROBLEMA ═════════════════════════════════════════════════════── -->
  <section class="bg-background" style="padding:3.5rem 1.5rem;">
    <div style="max-width:600px;margin:0 auto;text-align:center;">

      <h2 style="font-size:clamp(1.75rem,6vw,2.25rem);font-weight:800;line-height:1.3;color:hsl(204,96%,10%);margin:0 0 2rem;">
        Ti riconosci?
      </h2>

      <div style="display:flex;flex-direction:column;gap:1.25rem;text-align:left;max-width:420px;margin:0 auto 2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(6,63%,55%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Il tuo sito è vecchio.</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(6,63%,55%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Nessuno ti contatta.</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(6,63%,55%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">I clienti non ti trovano.</span>
        </div>
      </div>

      <p style="font-size:clamp(1.25rem,4vw,1.5rem);font-weight:700;color:hsl(38,90%,33%);margin:0;">
        Il problema è il sito.
      </p>
    </div>
  </section>


  <!-- ═══ LA SOLUZIONE ════════════════════════════════════════════════════── -->
  <section class="bg-cream" style="padding:3.5rem 1.5rem;">
    <div style="max-width:600px;margin:0 auto;text-align:center;">

      <h2 style="font-size:clamp(1.75rem,6vw,2.25rem);font-weight:800;line-height:1.3;color:hsl(204,96%,10%);margin:0 0 2rem;">
        Io te lo rifaccio.
      </h2>

      <div style="display:flex;flex-direction:column;gap:1.25rem;text-align:left;max-width:380px;margin:0 auto;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Bello da vedere.</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Facile da usare.</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Funziona sul telefono.</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.25rem;color:hsl(204,96%,10%);line-height:1.4;">Pronto in 5 giorni.</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ CTA INTERMEDIO ══════════════════════════════════════════════════── -->
  <section class="bg-background" style="padding:2.5rem 1.5rem;">
    <div style="max-width:400px;margin:0 auto;text-align:center;">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="display:block;background:#198844;color:#fff;font-size:1.25rem;font-weight:700;padding:1.1rem 2rem;border-radius:1rem;text-decoration:none;text-align:center;box-shadow:0 4px 14px rgba(25,136,68,0.4);transition:transform 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(25,136,68,0.5)'"
        onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 14px rgba(25,136,68,0.4)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;display:inline-block;vertical-align:middle;margin-right:8px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Mandami i siti d'esempio
      </a>
    </div>
  </section>


  <!-- ═══ ESEMPI (CASE STUDIES) ═══════════════════════════════════════════── -->
  <section class="bg-navy" style="padding:3rem 1.5rem;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:clamp(1.5rem,5vw,2rem);font-weight:800;color:#fff;text-align:center;margin:0 0 1.5rem;">
        Ecco cosa ho fatto.
      </h2>
      <CaseStudiesCarousel
        client:visible
        cases={serializedCases}
        basePath={basePath}
        variant="dark"
        clickable={false}
      />
    </div>
  </section>


  <!-- ═══ COME FUNZIONA ═══════════════════════════════════════════════════── -->
  <section class="bg-background" style="padding:3.5rem 1.5rem;">
    <div style="max-width:500px;margin:0 auto;text-align:center;">

      <h2 style="font-size:clamp(1.75rem,6vw,2.25rem);font-weight:800;line-height:1.3;color:hsl(204,96%,10%);margin:0 0 2.5rem;">
        Come funziona?
      </h2>

      <div style="display:flex;flex-direction:column;gap:2.5rem;">
        <!-- Step 1 -->
        <div>
          <div style="width:64px;height:64px;border-radius:50%;background:hsl(38,90%,33%);color:#fff;font-size:1.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 0.75rem;">1</div>
          <p style="font-size:1.25rem;font-weight:600;color:hsl(204,96%,10%);margin:0;">Mi scrivi su WhatsApp.</p>
        </div>
        <!-- Step 2 -->
        <div>
          <div style="width:64px;height:64px;border-radius:50%;background:hsl(38,90%,33%);color:#fff;font-size:1.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 0.75rem;">2</div>
          <p style="font-size:1.25rem;font-weight:600;color:hsl(204,96%,10%);margin:0;">Ti mando gli esempi.</p>
        </div>
        <!-- Step 3 -->
        <div>
          <div style="width:64px;height:64px;border-radius:50%;background:hsl(38,90%,33%);color:#fff;font-size:1.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 0.75rem;">3</div>
          <p style="font-size:1.25rem;font-weight:600;color:hsl(204,96%,10%);margin:0;">Se ti piace, partiamo.</p>
        </div>
      </div>

      <p style="font-size:1.1rem;color:hsl(204,96%,10%);opacity:0.78;margin:2rem 0 0;font-weight:600;">
        Tutto qui.
      </p>
    </div>
  </section>


  <!-- ═══ PREZZO ══════════════════════════════════════════════════════════── -->
  <section class="bg-cream" style="padding:3.5rem 1.5rem;">
    <div style="max-width:500px;margin:0 auto;text-align:center;background:#fff;border:3px solid hsl(38,90%,33%);border-radius:1.25rem;padding:2.5rem 2rem;box-shadow:0 8px 30px rgba(0,0,0,0.08);">

      <p style="font-size:clamp(3.5rem,12vw,4.5rem);font-weight:800;color:hsl(38,90%,33%);line-height:1;margin:0 0 0.5rem;">
        297 €
      </p>
      <p style="font-size:1.25rem;font-weight:600;color:hsl(204,96%,10%);margin:0 0 2rem;">
        Sito completo. Tutto compreso.
      </p>

      <div style="display:flex;flex-direction:column;gap:1rem;text-align:left;max-width:340px;margin:0 auto 2rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.1rem;color:hsl(204,96%,10%);">Design professionale</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.1rem;color:hsl(204,96%,10%);">Funziona sul telefono</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.1rem;color:hsl(204,96%,10%);">Pronto in 5 giorni</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="hsl(142,71%,35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
          <span style="font-size:1.1rem;color:hsl(204,96%,10%);">
            <strong>Garanzia:</strong> non ti piace? Ti ridò i soldi.
          </span>
        </div>
      </div>

      <!-- CTA WhatsApp -->
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="display:block;background:#198844;color:#fff;font-size:1.25rem;font-weight:700;padding:1.1rem 2rem;border-radius:1rem;text-decoration:none;text-align:center;box-shadow:0 4px 14px rgba(25,136,68,0.4);transition:transform 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(25,136,68,0.5)'"
        onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 14px rgba(25,136,68,0.4)'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;display:inline-block;vertical-align:middle;margin-right:8px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Mandami i siti d'esempio
      </a>
    </div>
  </section>


  <!-- ═══ CTA FINALE ══════════════════════════════════════════════════════── -->
  <section class="bg-navy" style="padding:3.5rem 1.5rem;">
    <div style="max-width:500px;margin:0 auto;text-align:center;">

      <p style="font-size:clamp(1.5rem,5vw,2rem);font-weight:700;color:#fff;line-height:1.4;margin:0 0 0.5rem;">
        Scrivimi. Vedi gli esempi.
      </p>
      <p style="font-size:clamp(1.5rem,5vw,2rem);font-weight:700;color:hsl(42,87%,55%);line-height:1.4;margin:0 0 2rem;">
        Poi decidi tu.
      </p>

      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="display:block;background:#198844;color:#fff;font-size:1.25rem;font-weight:700;padding:1.1rem 2rem;border-radius:1rem;text-decoration:none;text-align:center;max-width:400px;margin:0 auto;box-shadow:0 4px 14px rgba(25,136,68,0.4);transition:transform 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(25,136,68,0.5)'"
