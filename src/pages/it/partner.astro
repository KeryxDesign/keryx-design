---
import Layout from "../../layouts/Layout.astro";
import ReferralGenerator from "../../components/react/ReferralGenerator";
import davideFounder from "../../assets/davide-founder.webp";

const lang = "it";
---

<Layout
  title="Programma Referral Sito Keryx — Guadagna €100 per ogni persona | Keryx Design"
  description="Consiglia il Sito Keryx e guadagna €100 cash per ogni persona che porta a termine il progetto. Genera il tuo link personalizzato."
  lang={lang}
  showHeader={false}
  showFooter={false}
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
  <section class="bg-navy text-primary-foreground py-20 md:py-28">
    <div class="container max-w-3xl mx-auto px-6 text-center">
      <img
        src={davideFounder.src}
        alt="Davide Filippini — Keryx Design"
        class="w-20 h-20 rounded-full object-cover mx-auto mb-6 shadow-xl" style="outline: 3px solid rgba(240,180,40,0.4); outline-offset: 4px;"
        loading="eager"
      />
      <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-4">Programma Referral</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
        Guadagna €100 per ogni persona che porti.
      </h1>
      <p class="text-xl text-primary-foreground/80 max-w-2xl mx-auto leading-relaxed mb-8">
        Ogni persona che consigli paga <strong class="text-gold">€397 invece di €500</strong> per il Sito Keryx. Tu ricevi <strong class="text-gold">€100 cash</strong>. Nessun limite.
      </p>
      <a
        href="/it/sitokeryx/"
        class="inline-flex items-center gap-2 bg-gold hover:bg-[hsl(42,87%,45%)] text-navy font-bold px-7 py-3.5 rounded-xl shadow-lg transition-all hover:shadow-xl hover:-translate-y-0.5 text-base"
      >
        Anche tu hai bisogno di un sito?
        <span>&rarr;</span>
      </a>
    </div>
  </section>

  <!-- ═══ COME FUNZIONA ══════════════════════════════════════════════════════ -->
  <section class="bg-cream py-16 md:py-20">
    <div class="container max-w-3xl mx-auto px-6">
      <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">Come funziona</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-navy tracking-tight mb-12 text-center">
        3 passi. Zero complicazioni.
      </h2>
      <div class="space-y-10">
        <div class="flex gap-5 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">1</div>
          <div>
            <h3 class="font-display text-xl font-bold text-navy mb-2">Genera il tuo link</h3>
            <p class="text-foreground/70 leading-relaxed">Inserisci il tuo nome qui sotto. Ti creiamo un link personalizzato unico.</p>
          </div>
        </div>
        <div class="flex gap-5 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">2</div>
          <div>
            <h3 class="font-display text-xl font-bold text-navy mb-2">Condividilo</h3>
            <p class="text-foreground/70 leading-relaxed">Manda il link a chi vuoi su WhatsApp, Instagram o email. Ti diamo i messaggi già pronti.</p>
          </div>
        </div>
        <div class="flex gap-5 items-start">
          <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-white flex items-center justify-center font-bold text-xl">3</div>
          <div>
            <h3 class="font-display text-xl font-bold text-navy mb-2">Guadagna €100</h3>
            <p class="text-foreground/70 leading-relaxed">Per ogni persona che completa il progetto, ricevi <strong class="text-navy">€100 in contanti</strong>. Nessun limite.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GENERATORE LINK ════════════════════════════════════════════════════ -->
  <section class="bg-background py-16 md:py-20">
    <div class="container max-w-3xl mx-auto px-6">
      <ReferralGenerator client:visible />
    </div>
  </section>

  <!-- ═══ REGOLE ═════════════════════════════════════════════════════════════ -->
  <section class="bg-cream py-16 md:py-20">
    <div class="container max-w-3xl mx-auto px-6">
      <p class="text-xs font-bold tracking-[0.25em] uppercase text-gold mb-3 text-center">Le regole</p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-navy tracking-tight mb-8 text-center">
        Semplice e trasparente.
      </h2>
      <div class="max-w-xl mx-auto space-y-4 text-lg text-foreground/70 leading-relaxed">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong class="text-navy">Nessun limite</strong> — puoi portare quante persone vuoi</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong class="text-navy">€100 cash</strong> — pagati appena il progetto è completato</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong class="text-navy">Lo sconto dura 21 giorni</strong> — dal momento in cui generi il link</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong class="text-navy">Chi clicca il tuo link</strong> paga €397 invece di €500 per il Sito Keryx</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINALE ═════════════════════════════════════════════════════════ -->
  <section class="bg-navy text-primary-foreground py-16 md:py-20">
    <div class="container max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Hai domande?
      </h2>
      <p class="text-xl text-primary-foreground/80 leading-relaxed mb-8 max-w-xl mx-auto">
        Scrivimi su WhatsApp. Ti rispondo personalmente.
      </p>
      <a
        href="https://wa.me/393387445057?text=Ciao%20Davide%2C%20ho%20una%20domanda%20sul%20programma%20referral"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#128C7E] text-white font-bold text-lg px-10 py-5 rounded-xl shadow-xl transition-all hover:shadow-2xl hover:-translate-y-0.5 group"
      >
        <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current shrink-0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Scrivimi su WhatsApp
        <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </section>


</Layout>
