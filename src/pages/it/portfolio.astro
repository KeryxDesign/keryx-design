---
import Layout from "../../layouts/Layout.astro";
import { localPath } from "../../lib/i18n";
import PortfolioFilter from "../../components/react/PortfolioFilter";

import bookalogHolistic from "../../assets/portfolio/bookalog-holistic.webp";
import cartolinaCinofila from "../../assets/portfolio/cartolina-cinofila.webp";
import cartolinaDimagrimento from "../../assets/portfolio/cartolina-dimagrimento.webp";
import cartolinaFalegname from "../../assets/portfolio/cartolina-falegname.webp";
import flyerImmobiliare from "../../assets/portfolio/flyer-immobiliare.webp";
import libroAnubismo from "../../assets/portfolio/libro-anubismo.webp";
import libroBeforeAfter from "../../assets/portfolio/libro-before-after.webp";
import libroCommercialista from "../../assets/portfolio/libro-commercialista.webp";
import libroVino from "../../assets/portfolio/libro-vino.webp";
import libroSuperstizioni from "../../assets/portfolio/libro-superstizioni.webp";
import trifoldBushori from "../../assets/portfolio/trifold-bushori.webp";
import libroVeniVidiVictor from "../../assets/portfolio/libro-veni-vidi-victor.webp";
import magalogDentista from "../../assets/portfolio/magalog-dentista.webp";
import magalogGiardiniere from "../../assets/portfolio/magalog-giardiniere.webp";
import bookletBusiness from "../../assets/portfolio/booklet-business.webp";
import facebookCoverLaBaia from "../../assets/portfolio/facebook-cover-la-baia.webp";
import flyerLoveit from "../../assets/portfolio/flyer-loveit.webp";
import libroSuperstizioniCopertine from "../../assets/portfolio/libro-superstizioni-copertine.webp";
import rivistaFotovoltaico from "../../assets/portfolio/rivista-fotovoltaico.webp";
import libroAnarchiaQuotidiana from "../../assets/portfolio/libro-anarchia-quotidiana.webp";
import libroRivoluzioneEfficienza from "../../assets/portfolio/libro-rivoluzione-efficienza.webp";
import posterMindfullnest from "../../assets/portfolio/poster-mindfullnest.webp";
import trifoldHolidayAlbania from "../../assets/portfolio/trifold-holiday-albania.webp";
import cartolinaPalestra from "../../assets/portfolio/cartolina-palestra.webp";
import sostaCamperAfter from "../../assets/portfolio/sosta-camper-after.webp";
import magalogVerdetico from "../../assets/portfolio/magalog-verdetico.webp";
import menuLoveit from "../../assets/portfolio/menu-loveit.webp";

const lang = "it";

const whatsappUrl = `https://wa.me/3550695822380?text=${encodeURIComponent("Ciao, vorrei parlare dei vostri servizi di design")}`;

const categories = [
  { id: "all", label: "Tutti" },
  { id: "postcards", label: "Cartoline" },
  { id: "brochures", label: "Brochure" },
  { id: "books", label: "Libri" },
  { id: "posters", label: "Poster & Manifesti" },
  { id: "web", label: "Web & Landing" },
];

const categoryMap = Object.fromEntries(categories.map((c) => [c.id, c.label]));

const portfolioItems = [
  { id: 1, category: "postcards", image: cartolinaCinofila, title: "Cartolina Cinofila" },
  { id: 2, category: "postcards", image: cartolinaDimagrimento, title: "Cartolina Dimagrimento" },
  { id: 3, category: "postcards", image: cartolinaFalegname, title: "Cartolina Falegname" },
  { id: 4, category: "postcards", image: flyerImmobiliare, title: "Flyer Immobiliare" },
  { id: 5, category: "postcards", image: cartolinaPalestra, title: "Cartolina Palestra" },
  { id: 6, category: "postcards", image: flyerLoveit, title: "Flyer Pizzeria Love IT" },
  { id: 7, category: "brochures", image: trifoldBushori, title: "Trifold Bushori" },
  { id: 8, category: "brochures", image: magalogDentista, title: "Magalog Dentista" },
  { id: 9, category: "brochures", image: magalogGiardiniere, title: "Magalog Giardiniere" },
  { id: 10, category: "brochures", image: trifoldHolidayAlbania, title: "Holiday Albania Trifold" },
  { id: 11, category: "brochures", image: rivistaFotovoltaico, title: "Rivista Fotovoltaico Semplice" },
  { id: 12, category: "books", image: bookalogHolistic, title: "Libro Holistic" },
  { id: 13, category: "books", image: libroAnubismo, title: "Libro Anubismo" },
  { id: 14, category: "books", image: libroBeforeAfter, title: "Libri Before & After" },
  { id: 15, category: "books", image: libroCommercialista, title: "Libro Commercialista" },
  { id: 16, category: "books", image: libroVino, title: "Manifesto del Vino" },
  { id: 17, category: "books", image: libroSuperstizioni, title: "Libro Superstizioni" },
  { id: 18, category: "books", image: libroVeniVidiVictor, title: "Veni Vidi Victor" },
  { id: 19, category: "books", image: bookletBusiness, title: "Libro Decoratore" },
  { id: 20, category: "books", image: libroSuperstizioniCopertine, title: "La Pi\u00f9 Pericolosa delle Superstizioni" },
  { id: 21, category: "books", image: libroAnarchiaQuotidiana, title: "Anarchia Quotidiana" },
  { id: 22, category: "books", image: libroRivoluzioneEfficienza, title: "La Rivoluzione dell'Efficienza" },
  { id: 23, category: "posters", image: posterMindfullnest, title: "Poster MindfulNest" },
  { id: 24, category: "web", image: facebookCoverLaBaia, title: "Cover Facebook La Baia" },
  { id: 25, category: "brochures", image: sostaCamperAfter, title: "Brochure Sosta Camper" },
  { id: 26, category: "brochures", image: magalogVerdetico, title: "Magalog Verdetico" },
  { id: 27, category: "brochures", image: menuLoveit, title: "Menu Love IT" },
];

const serializedItems = portfolioItems.map((item) => ({
  id: item.id,
  category: item.category,
  imageSrc: item.image.src,
  title: item.title,
  categoryLabel: categoryMap[item.category] || item.category,
}));
---

<Layout
  title="Portfolio | Keryx Design"
  description="Scopri il nostro portfolio di Direct Response Design: cartoline, brochure, libri, poster e materiali digitali progettati per convertire."
  lang={lang}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-secondary/50 to-background py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl mb-6 text-foreground">
          Portfolio
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
          Una selezione dei nostri progetti di Direct Response Design &mdash; dalla stampa al digitale. Ogni pezzo &egrave; progettato per convertire, non solo per fare bella figura.
        </p>
      </div>
    </div>
  </section>

  <!-- Portfolio Filter + Grid -->
  <section class="bg-background">
    <div class="container mx-auto px-4">
      <PortfolioFilter
        client:load
        categories={categories}
        items={serializedItems}
      />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-secondary/30 py-20 lg:py-28">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mb-6 text-foreground">
        Vuoi un Risultato Simile?
      </h2>
      <p class="text-lg md:text-xl text-muted-foreground mb-10 leading-relaxed">
        Parliamo del tuo prossimo progetto. Progettiamo materiali cartacei e digitali che generano vendite misurabili &mdash; non solo complimenti.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-white text-lg px-10 py-4 font-bold rounded-lg shadow-lg transition-all hover:shadow-xl"
        style="background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Parla con noi
      </a>
    </div>
  </section>
</Layout>
