  <!-- ═══ TELEGRAM CHAT WIDGET ════════════════════════════════════════════ -->
  <!-- Panel (hidden by default via opacity+pointer-events) -->
  <div
    id="keryx-chat-panel"
    aria-hidden="true"
    style="
      position:fixed;
      bottom:1.25rem;
      right:1.25rem;
      width:calc(100% - 2.5rem);
      max-width:360px;
      z-index:9999;
      opacity:0;
      transform:translateY(24px);
      transition:opacity .22s ease, transform .22s ease;
      pointer-events:none;
    "
  >
    <div style="background:#fff;border-radius:1rem;box-shadow:0 24px 64px rgba(0,0,0,.22);overflow:hidden;">

      <!-- Header navy -->
      <div style="background:hsl(204,96%,10%);padding:.875rem 1.125rem;display:flex;align-items:center;justify-content:space-between;gap:.75rem;">
        <div style="display:flex;align-items:center;gap:.75rem;min-width:0;">
          <!-- Avatar gold K -->
          <div style="width:40px;height:40px;border-radius:50%;background:hsl(42,87%,55%);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.05rem;color:hsl(204,96%,10%);flex-shrink:0;font-family:serif;">K</div>
          <div style="min-width:0;">
            <div style="color:#fff;font-weight:600;font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">Davide — Keryx Design</div>
            <div style="color:rgba(255,255,255,.5);font-size:.68rem;display:flex;align-items:center;gap:.3rem;margin-top:2px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>
              Online lun–ven · 9:00–16:00
            </div>
          </div>
        </div>
        <button
          id="keryx-chat-close"
          aria-label="Chiudi chat"
          style="background:none;border:none;color:rgba(255,255,255,.5);cursor:pointer;padding:4px;line-height:0;border-radius:4px;flex-shrink:0;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Bot bubble -->
      <div style="padding:1.125rem 1.125rem .625rem;background:#f4f3ef;">
        <div style="background:#fff;border-radius:0 .875rem .875rem .875rem;padding:.8rem .95rem;display:inline-block;max-width:95%;box-shadow:0 1px 4px rgba(0,0,0,.07);">
          <p style="color:hsl(204,96%,10%);font-size:.84rem;line-height:1.55;margin:0;">
            Ciao! 👋 Sono Davide.<br>
            Scrivimi cosa ti serve e ti rispondo personalmente entro oggi&nbsp;(lun–ven, 9–16).
          </p>
        </div>
      </div>

      <!-- Form -->
      <div id="keryx-form-wrap" style="padding:.625rem 1.125rem 1.125rem;background:#f4f3ef;">
        <input
          id="keryx-name"
          type="text"
          placeholder="Il tuo nome"
          autocomplete="given-name"
          style="display:block;width:100%;padding:.575rem .8rem;border:1.5px solid #ddd;border-radius:.5rem;font-size:.84rem;outline:none;box-sizing:border-box;margin-bottom:.5rem;background:#fff;font-family:inherit;transition:border-color .15s;"
        />
        <textarea
          id="keryx-message"
          placeholder="Cosa ti serve? Descrivimelo in poche righe…"
          rows="3"
          style="display:block;width:100%;padding:.575rem .8rem;border:1.5px solid #ddd;border-radius:.5rem;font-size:.84rem;resize:none;outline:none;box-sizing:border-box;margin-bottom:.625rem;background:#fff;font-family:inherit;transition:border-color .15s;line-height:1.5;"
        ></textarea>
        <button
          id="keryx-send"
          style="display:block;width:100%;background:hsl(42,87%,55%);color:hsl(204,96%,10%);border:none;border-radius:.5rem;padding:.75rem;font-weight:700;font-size:.875rem;cursor:pointer;font-family:inherit;transition:filter .15s;"
        >Invia messaggio &rarr;</button>
        <p id="keryx-error" style="display:none;color:#ef4444;font-size:.72rem;margin:.4rem 0 0;text-align:center;">Scrivi il messaggio prima di inviare.</p>
      </div>

      <!-- Success state -->
      <div id="keryx-success" style="display:none;padding:2rem 1.25rem;background:#f4f3ef;text-align:center;">
        <div style="font-size:2.25rem;margin-bottom:.5rem;">✅</div>
        <p style="color:hsl(204,96%,10%);font-weight:700;font-size:1rem;margin:0 0 .375rem;">Messaggio inviato!</p>
        <p style="color:#64748b;font-size:.8rem;margin:0;line-height:1.55;">Ti rispondo personalmente<br>entro oggi lavorativo.</p>
      </div>

    </div>
  </div>

  <script is:inline define:vars={{ TG_TOKEN, TG_CHAT_ID }}>
  (function () {
    var panel    = document.getElementById('keryx-chat-panel');
    var closeBtn = document.getElementById('keryx-chat-close');
    var sendBtn  = document.getElementById('keryx-send');
    var formWrap = document.getElementById('keryx-form-wrap');
    var success  = document.getElementById('keryx-success');
    var nameEl   = document.getElementById('keryx-name');
    var msgEl    = document.getElementById('keryx-message');
    var errEl    = document.getElementById('keryx-error');

    function showPanel() {
      panel.style.pointerEvents = 'auto';
      panel.setAttribute('aria-hidden', 'false');
      panel.style.opacity = '1';
      panel.style.transform = 'translateY(0)';
      // focus primo campo
      setTimeout(function () { if (nameEl) nameEl.focus(); }, 230);
    }

    function hidePanel() {
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(24px)';
      panel.setAttribute('aria-hidden', 'true');
      setTimeout(function () { panel.style.pointerEvents = 'none'; }, 250);
    }

    // Apri dai due pulsanti della pagina
    ['keryx-chat-open', 'keryx-chat-open-cta'].forEach(function (id) {
      var btn = document.getElementById(id);
      if (btn) btn.addEventListener('click', function () {
        showPanel();
        if (typeof gtag === 'function') gtag('event', 'chat_open', { page_location: window.location.pathname });
        if (typeof fbq  === 'function') fbq('trackCustom', 'ChatOpen', { page: 'partner-sprint' });
      });
    });

    // Chiudi
    if (closeBtn) closeBtn.addEventListener('click', hidePanel);

    // Focus highlight nei campi
    [nameEl, msgEl].forEach(function (el) {
      if (!el) return;
      el.addEventListener('focus', function () { this.style.borderColor = 'hsl(42,87%,55%)'; });
      el.addEventListener('blur',  function () { this.style.borderColor = '#ddd'; });
    });

    // Invio
    if (sendBtn) sendBtn.addEventListener('click', function () {
      var name = (nameEl ? nameEl.value : '').trim() || 'Anonimo';
      var msg  = (msgEl  ? msgEl.value  : '').trim();

      if (!msg) {
        if (msgEl) msgEl.style.borderColor = '#ef4444';
        if (errEl) errEl.style.display = 'block';
        return;
      }
      if (errEl) errEl.style.display = 'none';

      sendBtn.disabled = true;
      sendBtn.style.filter = 'opacity(0.55)';
      sendBtn.textContent = 'Invio in corso\u2026';

      var text =
        '\uD83D\uDD14 <b>Nuovo messaggio \u00B7 Partner Sprint</b>\n\n' +
        '\uD83D\uDC64 <b>Nome:</b> ' + name + '\n\n' +
        '\uD83D\uDCAC <b>Messaggio:</b>\n' + msg;

      fetch('https://api.telegram.org/bot' + TG_TOKEN + '/sendMessage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: TG_CHAT_ID, text: text, parse_mode: 'HTML' })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.ok) {
            if (formWrap) formWrap.style.display = 'none';
            if (success)  success.style.display  = 'block';
            if (typeof gtag === 'function') gtag('event', 'chat_message_sent', { page_location: window.location.pathname });
            if (typeof fbq  === 'function') fbq('trackCustom', 'ChatMessageSent', { page: 'partner-sprint' });
          } else {
            sendBtn.disabled = false;
            sendBtn.style.filter = '';
            sendBtn.textContent = 'Invia messaggio \u2192';
            alert("Errore nell'invio. Riprova tra un momento.");
          }
        })
        .catch(function () {
          sendBtn.disabled = false;
          sendBtn.style.filter = '';
          sendBtn.textContent = 'Invia messaggio \u2192';
          alert('Errore di rete. Controlla la connessione e riprova.');
        });
    });
  })();
  </script>
  <!-- ════════════════════════════════════════════════════════════════════════ -->
</Layout>
