---
import Layout from "../../layouts/Layout.astro";
import { localPath } from "../../lib/i18n";
import { getTestimonials } from "../../content/testimonials";
import { getCaseStudies } from "../../content/caseStudies";
import TestimonialsCarousel from "../../components/react/TestimonialsCarousel";
import CaseStudiesCarousel from "../../components/react/CaseStudiesCarousel";
import FAQAccordion from "../../components/react/FAQAccordion";
import davideFounder from "../../assets/davide-founder.webp";

const lang = "it";
const testimonials = getTestimonials(lang);
const caseStudies = getCaseStudies(lang);

// ─── Telegram Chat Widget ─────────────────────────────────────────────────────
const TG_TOKEN   = "8785771604:AAF4vFqUAQ0XINwQVzeECBCnlZMXFCVhQsk";
const TG_CHAT_ID = "457640136";
// ─────────────────────────────────────────────────────────────────────────────

const basePath = localPath("/blog/case-studies", lang);

const serializedTestimonials = testimonials.map((t) => ({
  quote: t.quote,
  author: t.author,
  role: t.role,
  imageSrc: t.image.src,
}));

const serializedCases = caseStudies.map((c) => ({
  slug: c.slug,
  thumbnailSrc: c.thumbnail.src,
}));

const faqs = [
  {
    question: "Quanti task riusciamo a finire in uno Sprint?",
    answer: "Dipende dalla complessit\u00e0. Una grafica social \u00e8 circa un giorno, un flyer fronte/retro due giorni, una landing page due giorni, un Lead Magnet da 12 pagine tre-quattro. In 10 giorni un esempio realistico \u00e8: 3 grafiche social + 1 flyer + 1 landing + 3 varianti ads. La chiarezza del tuo brief e la velocit\u00e0 dei tuoi feedback sono il turbo dello Sprint.",
  },
  {
    question: "Che tipo di grafiche posso chiedere?",
    answer: "Qualsiasi materiale di marketing, cartaceo o digitale. Ads per Facebook e Google, landing page, sales letter, magalog, brochure, flyer, email, post social, presentazioni, lead magnet, opt-in page, materiali per fiere \u2014 tutto.",
  },
  {
    question: "Quanto ci metti a consegnare?",
    answer: "Ogni richiesta riceve un aggiornamento o una consegna entro 24-48 ore lavorative. Per pezzi complessi (magalog, funnel multipagina) le 24-48h si riferiscono al prossimo update, non al deliverable finito.",
  },
  {
    question: "E se il risultato non mi convince?",
    answer: "Revisioni incluse, sempre. Lavoro finch\u00e9 non \u00e8 perfetto.",
  },
  {
    question: "Cosa succede se ho bisogno di un piccolo intervento dopo i 10 giorni dello Sprint?",
    answer: "Per piccoli aggiornamenti offriamo il ticket \"Single Project\" a preventivo. Ma per la massima efficienza economica consiglio sempre lo Sprint. Se invece capisci che il tuo marketing ha bisogno di cure costanti, puoi passare al Retainer in qualsiasi momento \u2014 e ti scomputo il 50% dello Sprint dal primo mese.",
  },
  {
    question: "Sprint o Retainer: quale scelgo?",
    answer: "Se hai una lista di grafiche da far fare e vuoi svuotarla in fretta: Sprint. Se produci materiali ogni settimana e vuoi un designer sempre al tuo fianco: Retainer. Se non sei sicuro, parti dallo Sprint \u2014 \u00e8 il modo migliore per provare la differenza.",
  },
  {
    question: "Devo impegnarmi per mesi?",
    answer: "No. Lo Sprint \u00e8 un acquisto singolo \u2014 finiti i 10 giorni, zero obblighi. Il Retainer \u00e8 un abbonamento mensile con disdetta libera in qualsiasi momento.",
  },
  {
    question: "Cosa intendi con 'orientato alla vendita'?",
    answer: "Ogni scelta di design \u2014 font, colori, layout, dimensioni, posizionamento \u2014 \u00e8 fatta per guidare il lettore verso un'azione: cliccare, chiamare, compilare, comprare. Non faccio \"arte.\" Faccio grafiche che lavorano per il tuo fatturato.",
  },
];
---

<Layout
  title="Keryx Partner Sprint — Tutte le Grafiche in 10 Giorni"
  description="Ads, flyer, sales letter, landing page, email, brochure — 10 giorni di Direct Response Design puro per svuotare il tuo cassetto di task arretrati. &euro;997."
  lang={lang}
  showHeader={false}
>
  <!-- TOP BAR — no header, so top-0 -->
  <div class="fixed top-0 left-0 right-0 z-40 bg-coral text-white text-center py-2 text-sm font-medium tracking-wide">
    <svg class="inline-block w-4 h-4 mr-1.5 -mt-0.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
    Accettiamo massimo <strong>3 nuovi clienti</strong> al mese
  </div>

  <!-- pt-9 = spazio per la top bar fissa (~36px) -->
  <div class="pt-9">

    <!-- HERO -->
    <section class="relative min-h-[75vh] flex items-center bg-marble">
      <div class="container max-w-4xl mx-auto px-6 py-12 md:py-20 text-center">
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-foreground leading-tight mb-6">
          Tutte le Grafiche Che Ti Servono.
          <span class="text-primary">Pronte in 10 Giorni.</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-3xl mx-auto mb-4 leading-relaxed">
          Ads, flyer, sales letter, landing page, email, brochure &mdash; hai una lista infinita di materiali da produrre e nessun designer che capisca il marketing?
          <strong class="text-foreground">Keryx Partner Sprint:</strong> 10 giorni di Direct Response Design puro per svuotare il tuo cassetto di task arretrati.
        </p>
        <p class="text-base md:text-lg text-muted-foreground max-w-2xl mx-auto mb-10 leading-relaxed">
          Ogni colore, ogni font, ogni layout &egrave; scelto per guidare il lettore verso un&rsquo;azione. Non vinciamo premi &mdash; <mark class="bg-gold/30 text-foreground px-1 rounded">generiamo vendite misurabili.</mark> <strong>Su stampa e digitale.</strong>
        </p>

        <button
          id="keryx-chat-open"
          class="inline-flex items-center gap-3 bg-navy text-white text-base md:text-lg px-8 py-5 font-semibold rounded-xl shadow-lg transition-all hover:shadow-xl hover:-translate-y-0.5 group"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          Verifica disponibilit&agrave; con Davide
          <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
        </button>

        <div class="mt-6 flex items-center justify-center gap-1.5 text-sm text-muted-foreground">
          <span class="w-2 h-2 rounded-full bg-gold animate-pulse inline-block"></span>
          <span class="font-medium text-foreground">Posti disponibili per marzo: 3</span>
        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF -->
    <section class="py-12 lg:py-20 bg-primary">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mb-4 text-primary-foreground">
            Cosa Dicono Copywriter e Marketer
          </h2>
        </div>
        <TestimonialsCarousel
          client:visible
          testimonials={serializedTestimonials}
          variant="dark"
        />
      </div>
    </section>

    <!-- IL COSTO NASCOSTO -->
    <section class="bg-background py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <div class="flex flex-col items-center mb-8">
          <svg class="w-10 h-10 text-gold mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-center">
            Quanto Ti Costa Avere le Grafiche Ferme?
          </h2>
        </div>
        <div class="space-y-5 text-lg text-muted-foreground leading-relaxed text-left">
          <p><strong class="text-foreground">Non parliamo solo di soldi. Parliamo di tempo.</strong></p>
          <p>
            Ogni giorno che quella Sales Letter resta nel cassetto perch&eacute; manca l&rsquo;impaginazione, ogni settimana che quelle ads non girano perch&eacute; il designer non ha consegnato, ogni mese che il funnel non &egrave; online perch&eacute; <em>&ldquo;il grafico sta ancora lavorando&rdquo;</em> &mdash; <mark class="bg-gold/30 text-foreground px-1 rounded">stai regalando quote di mercato ai tuoi concorrenti.</mark>
          </p>
          <p>
            Il tuo collo di bottiglia non &egrave; il budget. Non &egrave; il copy. Non &egrave; la strategia. <strong class="text-foreground">&Egrave; l&rsquo;esecuzione grafica.</strong> E il Keryx Partner Sprint &egrave; la cura per la paralisi esecutiva.
          </p>
        </div>
      </div>
    </section>

    <!-- PAIN SECTION -->
    <section class="bg-cream py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <div class="flex flex-col items-center mb-8">
          <svg class="w-10 h-10 text-gold mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 10h.01M15 10h.01M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/></svg>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-center">Ti &Egrave; Mai Capitato?</h2>
        </div>
        <div class="space-y-5 text-lg text-muted-foreground leading-relaxed text-left">
          <p>
            Ti &egrave; mai capitato di spiegare al grafico cosa ti serve e <strong class="text-foreground">aspettare giorni</strong>? E poi altri giorni per le revisioni. E intanto la tua campagna &mdash; quella bella, quella pronta, quella che doveva partire ieri &mdash; <mark class="bg-gold/30 text-foreground px-1 rounded">resta ferma.</mark>
          </p>
          <p>
            Poi ricevi la grafica e pensi: <em>&ldquo;b&egrave;, questa mia figlia l&rsquo;avrebbe fatta meglio.&rdquo;</em>
          </p>
          <p>
            Cambi grafico. <strong class="text-foreground">Ricominci da capo.</strong> Rispieghi tutto. Il brand, il tono, il target. E finisci allo stesso punto.
          </p>
          <p>
            E allora torni su Canva. Ti illudi che ti &egrave; venuta carina. Ma adesso ti ritrovi a fare il segretario e il grafico di te stesso, <em>alle 11 di sera</em>, <mark class="bg-gold/30 text-foreground px-1 rounded">rubando ore al tuo vero lavoro.</mark>
          </p>
        </div>
        <div class="mt-10 p-6 bg-background rounded-lg border-l-4 border-gold">
          <p class="text-lg leading-relaxed text-foreground">
            <strong>Il problema non &egrave; trovare un grafico migliore.</strong> Il problema &egrave; trovare un grafico che capisca il marketing.
          </p>
        </div>
      </div>
    </section>

    <!-- COME FUNZIONA -->
    <section id="come-funziona" class="bg-navy text-primary-foreground py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <div class="flex flex-col items-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-center">
            Keryx Partner Sprint: Come Funziona in 10 Giorni
          </h2>
        </div>

        <div class="space-y-10">
          <!-- Step 1 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold text-navy font-bold text-xl flex items-center justify-center">1</div>
            <div>
              <h3 class="font-display text-xl font-bold mb-2">Prepara la Tua Lista</h3>
              <p class="text-primary-foreground/80 leading-relaxed">Metti in fila tutto ci&ograve; che ti serve. 5 Facebook Ads. Un pieghevole. L&rsquo;impaginazione di un report. 3 mockup per il sito. Una sales letter. Tutto quello che hai nel cassetto.</p>
            </div>
          </div>
          <!-- Step 2 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold text-navy font-bold text-xl flex items-center justify-center">2</div>
            <div>
              <h3 class="font-display text-xl font-bold mb-2">Lavorazione in Sequenza</h3>
              <p class="text-primary-foreground/80 leading-relaxed">Io inizio dal task #1. Appena ricevo il tuo OK, passo al #2. E cos&igrave; via, per 10 giorni lavorativi. Una richiesta alla volta, massima qualit&agrave; su ogni pezzo.</p>
            </div>
          </div>
          <!-- Step 3 -->
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-gold text-navy font-bold text-xl flex items-center justify-center">3</div>
            <div>
              <h3 class="font-display text-xl font-bold mb-2">Consegne Ogni 24-48h</h3>
              <p class="text-primary-foreground/80 leading-relaxed">Non aspetti la fine dello Sprint per vedere i risultati. Ricevi output continui. Pi&ugrave; sei veloce nel darmi feedback, pi&ugrave; task riusciamo a smarcare.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- IL CARRELLO -->
    <section class="bg-cream py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <div class="flex flex-col items-center mb-10">
          <svg class="w-10 h-10 text-gold mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-center">
            Cosa Puoi Smarcare in Uno Sprint?
          </h2>
          <p class="text-muted-foreground mt-2 text-center">(Esempio Reale)</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 mb-10">
          <div class="flex items-start gap-3 bg-background p-4 rounded-lg border border-border shadow-sm">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground leading-relaxed">3 grafiche per i social</span>
          </div>
          <div class="flex items-start gap-3 bg-background p-4 rounded-lg border border-border shadow-sm">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground leading-relaxed">1 flyer fronte/retro</span>
          </div>
          <div class="flex items-start gap-3 bg-background p-4 rounded-lg border border-border shadow-sm">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground leading-relaxed">1 landing page</span>
          </div>
          <div class="flex items-start gap-3 bg-background p-4 rounded-lg border border-border shadow-sm">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground leading-relaxed">3 varianti di Facebook/Instagram Ads</span>
          </div>
        </div>

        <div class="p-6 bg-background rounded-lg border-l-4 border-gold">
          <p class="text-lg leading-relaxed text-foreground">
            Tutto questo con un unico investimento di <strong>&euro;997.</strong> Invece di pagare mille preventivi separati, aspettare settimane, e coordinare tre freelancer diversi.
          </p>
        </div>
      </div>
    </section>

    <!-- TABELLA DI CONFRONTO -->
    <section class="bg-background py-20 md:py-28">
      <div class="container max-w-4xl mx-auto px-6">
        <div class="flex flex-col items-center mb-10">
          <svg class="w-10 h-10 text-gold mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-center">
            Keryx Partner: Due Modalit&agrave;.
          </h2>
          <p class="text-xl text-muted-foreground mt-2 text-center">Scegli Quella Giusta per Te.</p>
        </div>

        <div class="rounded-xl overflow-hidden shadow-card border border-border max-w-4xl mx-auto text-sm md:text-base">
          <!-- Header -->
          <div class="grid grid-cols-2">
            <div class="bg-gold/10 p-5 md:p-6 border-b border-r border-border text-center">
              <span class="font-display font-bold text-foreground text-2xl md:text-3xl">SPRINT</span>
              <p class="text-xs text-muted-foreground mt-1">&ldquo;Lo Svuota-Cassetto&rdquo;</p>
            </div>
            <div class="bg-navy p-5 md:p-6 border-b text-center">
              <span class="font-display font-bold text-gold text-2xl md:text-3xl">RETAINER</span>
              <p class="text-xs text-primary-foreground/60 mt-1">&ldquo;Il Reparto Grafico Interno&rdquo;</p>
            </div>
          </div>

          <!-- Row 1 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">10 giorni lavorativi</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Rinnovo mensile</div>
          </div>
          <!-- Row 2 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">1 richiesta alla volta, consegne 24-48h</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">1 richiesta alla volta, consegne 24-48h</div>
          </div>
          <!-- Row 3 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Tutto: stampa, digital, ads, web, email</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Tutto: stampa, digital, ads, web, email</div>
          </div>
          <!-- Row 4 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Archivio brand dedicato in cloud</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Archivio brand dedicato in cloud</div>
          </div>
          <!-- Row 5 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Call iniziale + call di consegna finale</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Call strategica settimanale 45 min</div>
          </div>
          <!-- Row 6 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">&mdash;</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Assistenza diretta WhatsApp lun-ven</div>
          </div>
          <!-- Row 7 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">&mdash;</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Priorit&agrave; sulle consegne rispetto agli Sprint</div>
          </div>
          <!-- Row 8 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">&mdash;</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Revisione strategica mensile dei materiali esistenti</div>
          </div>
          <!-- Row 9 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Esecuzione pura</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Esecuzione + consulenza strategica</div>
          </div>
          <!-- Row 10 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Zero impegno. Finiti i 10 giorni, amici come prima.</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">Disdetta libera, quando vuoi.</div>
          </div>
          <!-- Row 11 -->
          <div class="grid grid-cols-2">
            <div class="p-3 md:p-4 border-b border-r border-border text-muted-foreground leading-relaxed">Passa al Retainer e recupera il 50% dello Sprint</div>
            <div class="p-3 md:p-4 border-b border-border bg-navy/5 text-foreground leading-relaxed font-medium">&mdash;</div>
          </div>

          <!-- Riga COSTO -->
          <div class="grid grid-cols-2">
            <div class="p-6 md:p-8 border-r border-border bg-gold/10 flex flex-col items-center justify-center">
              <span class="font-display text-3xl md:text-4xl font-bold text-foreground">&euro;997</span>
              <span class="text-sm text-muted-foreground mt-1">una tantum</span>
            </div>
            <div class="p-6 md:p-8 bg-navy flex flex-col items-center justify-center">
              <span class="font-display text-3xl md:text-4xl font-bold text-gold">&euro;1.997</span>
              <span class="text-sm text-primary-foreground/60 mt-1">/mese</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SEZIONE RETAINER -->
    <section class="bg-navy text-primary-foreground py-20 md:py-28">
      <div class="container max-w-3xl mx-auto px-6">
        <div class="flex flex-col items-center mb-8">
