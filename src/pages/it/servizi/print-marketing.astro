---
import Layout from "../../../layouts/Layout.astro";
import { localPath } from "../../../lib/i18n";
import TestimonialsCarousel from "../../../components/react/TestimonialsCarousel";
import FAQAccordion from "../../../components/react/FAQAccordion";
import founderImage from "../../../assets/davide-founder.webp";
import giacomoBrandi from "../../../assets/testimonials/giacomo-brandi.webp";
import andreaDallan from "../../../assets/testimonials/andrea-dallan.webp";
import fabioCagnetti from "../../../assets/testimonials/fabio-cagnetti.webp";
import ericaZuanon from "../../../assets/testimonials/erica-zuanon.webp";
import fabrizioMarino from "../../../assets/testimonials/fabrizio-marino.webp";
import lucaBelardinelli from "../../../assets/testimonials/luca-belardinelli.webp";

const lang = "it";
const tallyUrl = "https://tally.so/r/wbXzq6";

const testimonials = [
  {
    quote: "In oltre trent'anni di lavoro, mi sono affidato a tanti grafici. Non li cambier\u00F2 mai pi\u00F9. La semplicit\u00E0 con cui trasformano un'idea in un volantino, un manifesto, un magazine \u00E8 straordinaria.",
    author: "Giacomo Brandi",
    role: "Agente Immobiliare",
    imageSrc: giacomoBrandi.src,
  },
  {
    quote: "2.500 copie del libro vendute e anche dopo cinque anni, la gente continua a dirmi: 'Ah, sei tu quello che ha scritto\u2026'. Ora devo lavorare a una seconda edizione.",
    author: "Fabio Cagnetti",
    role: "Imprenditore",
    imageSrc: fabioCagnetti.src,
  },
  {
    quote: "Ero alla ricerca di un designer a risposta diretta in grado di aiutarmi a strutturare la strategia visiva in uno dei business pi\u00F9 difficili.",
    author: "Luca Belardinelli",
    role: "Imprenditore",
    imageSrc: lucaBelardinelli.src,
  },
  {
    quote: "Lavoriamo con Davide e il suo team da oltre un anno, e ogni materiale di marketing che produciamo passa attraverso di loro.",
    author: "Fabrizio Marino",
    role: "Marketing Manager",
    imageSrc: fabrizioMarino.src,
  },
  {
    quote: "Rendere un libro di marketing diretto piacevole e coinvolgente non \u00E8 sempre facile. In questo caso, il risultato \u00E8 altamente professionale.",
    author: "Andrea Dallan",
    role: "CEO Dallan S.p.a.",
    imageSrc: andreaDallan.src,
  },
  {
    quote: "Consiglierei di lavorare con Davide a tutti quegli imprenditori e professionisti che comprendono davvero l'importanza del marketing.",
    author: "Erica Zuanon",
    role: "Imprenditrice",
    imageSrc: ericaZuanon.src,
  },
];

const faqs = [
  { question: "Devo avere gi\u00E0 una lista email?", answer: "No. Il sistema serve a costruirla." },
  { question: "Funziona per servizi?", answer: "S\u00EC. Qualsiasi attivit\u00E0 con traffico fisico." },
  { question: "Serve un sito web?", answer: "No. Pu\u00F2 portare a WhatsApp, Instagram o form." },
  { question: "E se i clienti non scansionano?", answer: "Garanzia: meno di 20 contatti = rifacimento gratis." },
  { question: "Posso ristampare dopo?", answer: "S\u00EC. File \u00E8 tuo. Ristampi a 60\u20AC per 1.000 cartoline." },
  { question: "Perch\u00E9 prezzo basso?", answer: "Validazione. Primi 10: 497\u20AC. Dopo: 797\u20AC." },
];
---

<Layout
  title="Print Marketing | Keryx Design - Trasforma Il Traffico In Contatti Digitali"
  description="500 cartoline che raccolgono lead mentre tu vendi. Trasforma il traffico del tuo negozio in contatti digitali automatici con il Direct Response Design."
  lang={lang}
>
  <!-- ============================================= -->
  <!-- HERO SECTION - Marble background              -->
  <!-- ============================================= -->
  <section class="relative min-h-[80vh] flex items-center bg-marble">
    <div class="container mx-auto px-4 py-20 lg:py-28">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-tight mb-6 text-foreground">
          Trasforma Il Traffico Del Tuo Negozio In Contatti Digitali Automatici
        </h1>
        <p class="text-xl md:text-2xl lg:text-3xl text-primary font-display italic mb-10">
          500 Cartoline Che Raccolgono Lead Mentre Tu Vendi
        </p>

        <!-- Price Box -->
        <div class="max-w-md mx-auto mb-6">
          <p class="text-muted-foreground line-through text-xl mb-3">Prezzo Normale: 797&euro;</p>
          <div class="text-white rounded-xl p-5 inline-flex items-center gap-2" style="background: linear-gradient(135deg, #D4A84B 0%, #B8942E 100%);">
            <!-- Flame icon -->
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
            </svg>
            <span class="text-2xl font-bold">OFFERTA LANCIO: 497&euro;</span>
          </div>
        </div>

        <!-- Authority Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full">
          <!-- Award icon -->
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="6"/>
            <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
          <p class="text-sm font-medium text-primary">
            Primi Direct Response Designer in Europa
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- PROBLEM SECTION - Dark background             -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-primary text-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-12">
        Il Problema
      </h2>
      <div class="space-y-6 text-lg md:text-xl leading-relaxed">
        <p class="text-white/80">Ogni giorno entrano decine di persone nel tuo negozio.</p>
        <p class="text-white font-bold text-2xl">Non raccogli nemmeno una email.</p>
        <p class="text-white/80">Poi paghi 20&euro; per lead freddi su Facebook.</p>
      </div>
      <p class="text-3xl font-bold text-gold mt-12 font-display">
        C&rsquo;&egrave; un modo migliore.
      </p>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- WHAT YOU GET SECTION - Light with cards        -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-background">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        Cosa Ricevi
      </h2>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          { title: "Call Strategica (60 min)", desc: "Analizziamo il tuo business e troviamo l'offerta perfetta per raccogliere contatti." },
          { title: "Copy + Design Professionale", desc: 'Cartolina progettata per massimizzare scansioni QR. Non "bella", ma efficace.' },
          { title: "500 Cartoline Stampate", desc: "Pronte da distribuire. Gestisco io stampa e spedizione." },
          { title: "File PDF Pronto Stampa", desc: "Tuo per sempre. Ristampi quando vuoi (60\u20AC per 1.000)." },
          { title: "2 Follow-Up (30 giorni)", desc: "Analizziamo risultati e ottimizziamo." },
          { title: "Report Risultati", desc: "Scansioni, lead raccolti, costo per lead. Numeri veri." },
          { title: "1 Revisione Inclusa", desc: "" },
        ].map((item, index) => (
          <div class="bg-card border border-border rounded-2xl p-5 hover:border-primary/50 transition-all hover:shadow-card group">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 bg-primary rounded-xl flex items-center justify-center group-hover:bg-primary/90 transition-colors">
                <span class="text-white font-bold text-lg">{index + 1}</span>
              </div>
              <div>
                <h3 class="font-bold text-foreground mb-1">{item.title}</h3>
                {item.desc && <p class="text-muted-foreground text-sm">{item.desc}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- HOW IT WORKS SECTION - Gradient background    -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-gradient-to-br from-primary/5 via-background to-gold/5">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        Come Funziona
      </h2>
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary via-gold to-primary/30"></div>

        <div class="space-y-8">
          {[
            { week: "SETTIMANA 1", desc: "Call strategica \u2192 Scrivo copy e design \u2192 Ti mando per approvazione" },
            { week: "SETTIMANA 2", desc: "Approvazione finale \u2192 Gestisco stampa \u2192 Ti spedisco 500 cartoline" },
            { week: "GIORNI 10-40", desc: "Distribuisci \u2192 Raccogli contatti \u2192 Follow-up ai giorni 15 e 30" },
          ].map((step, index) => (
            <div class="flex gap-6 relative">
              <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center z-10 shadow-lg bg-gold">
                <span class="text-white font-bold">{index + 1}</span>
              </div>
              <div class="bg-card border border-border rounded-xl p-5 flex-1">
                <h3 class="font-bold text-primary mb-2">{step.week}</h3>
                <p class="text-muted-foreground">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12 bg-primary text-primary-foreground rounded-2xl p-6 text-center">
        <p class="font-semibold text-lg">Timeline: Dalla call alle cartoline pronte: 10 giorni lavorativi</p>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- RESULTS SECTION - Dark with gradient cards    -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-primary">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-12 text-center">
        Risultati Reali
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Personal Trainer -->
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:border-gold/50 transition-all group">
          <div class="w-12 h-12 bg-gold/20 rounded-xl flex items-center justify-center mb-4 group-hover:bg-gold/30 transition-colors">
            <!-- TrendingUp icon -->
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <p class="text-white/70 text-sm mb-2">Personal Trainer</p>
          <p class="text-4xl font-bold text-white mb-2">1.700&euro;</p>
          <p class="text-white/80">fatturati da un singolo invio</p>
        </div>

        <!-- Negozio Locale -->
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:border-gold/50 transition-all group">
          <div class="w-12 h-12 bg-gold/20 rounded-xl flex items-center justify-center mb-4 group-hover:bg-gold/30 transition-colors">
            <!-- Users icon -->
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <p class="text-white/70 text-sm mb-2">Negozio Locale</p>
          <p class="text-4xl font-bold text-white mb-2">500+</p>
          <p class="text-white/80">email raccolte in 4 mesi</p>
        </div>

        <!-- Agente Immobiliare -->
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:border-gold/50 transition-all group">
          <div class="w-12 h-12 bg-gold/20 rounded-xl flex items-center justify-center mb-4 group-hover:bg-gold/30 transition-colors">
            <!-- Euro icon -->
            <svg class="w-6 h-6 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10h12"/>
              <path d="M4 14h9"/>
              <path d="M19 6a7.7 7.7 0 0 0-5.2-2A7.9 7.9 0 0 0 6 12a7.9 7.9 0 0 0 7.8 8 7.7 7.7 0 0 0 5.2-2"/>
            </svg>
          </div>
          <p class="text-white/70 text-sm mb-2">Agente Immobiliare</p>
          <p class="text-4xl font-bold text-white mb-2">12.000&euro;</p>
          <p class="text-white/80">fatturati</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- GUARANTEE SECTION - Green accent              -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-gradient-to-br from-green-50 to-emerald-50 border-y border-green-200">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-20 h-20 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-lg shadow-green-500/30">
        <!-- Shield icon -->
        <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
        </svg>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
        Garanzia Performance
      </h2>
      <div class="bg-card border-2 border-green-400 rounded-2xl p-8">
        <p class="text-muted-foreground text-lg">Se distribuisci tutte le 500 cartoline entro 30 giorni e raccogli meno di 20 contatti, te ne creo una nuova GRATIS.</p>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- ABOUT SECTION - Light                         -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-background">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        Chi Sono
      </h2>
      <div class="flex flex-col md:flex-row gap-8 items-center md:items-start mb-12">
        <img
          src={founderImage.src}
          alt="Davide Filippini"
          class="w-40 h-40 rounded-2xl object-cover shadow-xl"
        />
        <div class="flex-1">
          <h3 class="font-bold text-2xl text-foreground">Davide Filippini</h3>
          <p class="text-primary font-medium mb-4">Primo Designer A Risposta Diretta in Italia</p>
          <div class="text-muted-foreground space-y-4 mb-6">
            <p>Davide Filippini ha iniziato nel marketing a 16 anni, aiutando un negozio locale a crescere sui social.</p>
            <p>Ma venendo da una famiglia di imprenditori, ha capito subito una cosa: il marketing deve vendere. Non intrattenere.</p>
            <p>Durante gli studi di grafica, ha scoperto che l&rsquo;accademia ignorava completamente la vendita.</p>
            <p>Cos&igrave; ha fatto reverse engineering dei grandi: Hopkins, Ogilvy, Halbert.</p>
            <p>Ha scoperto che il Direct Response Design esisteva. Ma in Italia, nessuno lo faceva.</p>
          </div>
          <div class="bg-primary/10 rounded-xl p-4">
            <h4 class="font-bold text-primary mb-2">La Svolta</h4>
            <p class="text-muted-foreground text-sm">3 anni come Chief Design Officer di Metodo Merenda, coordinando design, copy, web, vendite e stampa. Formazione diretta con Lori Haller, la pi&ugrave; famosa Direct Response Designer negli Stati Uniti. Primo studente italiano del suo metodo. Ogni progetto supervisionato personalmente. Ogni decisione basata su neuroscienze e test reali.</p>
          </div>
        </div>
      </div>

      <!-- Testimonials Carousel -->
      <TestimonialsCarousel
        client:visible
        testimonials={testimonials}
      />
    </div>
  </section>

  <!-- ============================================= -->
  <!-- FOR YOU SECTION - Gradient                    -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-gradient-to-br from-primary/5 via-background to-gold/5">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        &Egrave; Per Te Se
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-card border border-green-300 rounded-2xl p-6">
          <div class="space-y-4">
            {[
              "Hai un negozio fisico con traffico regolare",
              "Vuoi costruire un database di contatti",
              "Sei disposto a distribuire le cartoline",
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0">
                  <!-- Check icon -->
                  <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span class="text-foreground">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-card border border-red-300 rounded-2xl p-6">
          <div class="space-y-4">
            {[
              "Non \u00E8 per te se hai solo business online",
              "Non hai traffico fisico",
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0">
                  <!-- X icon -->
                  <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18"/>
                    <path d="m6 6 12 12"/>
                  </svg>
                </div>
                <span class="text-muted-foreground">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- INVESTMENT SECTION - Dark with highlight      -->
  <!-- ============================================= -->
  <section class="py-20 px-4 bg-primary">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-12 text-center">
        Investimento
      </h2>

      <div class="bg-white/5 backdrop-blur border-2 border-gold rounded-3xl p-8 shadow-2xl shadow-gold/10">
        <div class="text-center mb-6">
          <p class="text-white/60 line-through text-xl">PREZZO NORMALE: 797&euro;</p>
          <div class="text-white rounded-xl p-4 mt-4 inline-flex items-center gap-2" style="background: linear-gradient(135deg, #D4A84B 0%, #B8942E 100%);">
            <!-- Flame icon -->
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
            </svg>
            <span class="text-2xl font-bold">PREZZO LANCIO: 497&euro;</span>
          </div>
          <p class="text-gold font-bold mt-3 text-lg">RISPARMIO: 300&euro;</p>
        </div>

        <div class="bg-white/5 rounded-xl p-4 mb-6 text-center">
          <p class="font-semibold text-white">Perch&eacute; questo prezzo?</p>
          <p class="text-white/60 text-sm mt-1">Primi 10 clienti pagano 497&euro; in cambio di feedback e testimonianza. Dal cliente #11 in poi: 797&euro;.</p>
        </div>

        <div class="mb-6">
          <p class="font-semibold text-white mb-3">Include:</p>
          <div class="grid grid-cols-2 gap-2">
            {[
              "Call Strategica (60 min)",
              "Copy + Design Professionale",
              "500 Cartoline Stampate",
              "File PDF",
              "2 Follow-Up",
              "Report Risultati",
              "1 Revisione",
              "Garanzia Doppia",
            ].map((item) => (
              <div class="flex items-center gap-2">
                <!-- Check icon -->
                <svg class="w-4 h-4 text-gold flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-white/80 text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <a href={tallyUrl} target="_blank" rel="noopener noreferrer" class="block">
          <button class="w-full text-white text-lg py-6 font-bold rounded-lg cursor-pointer transition-opacity hover:opacity-90" style="background: linear-gradient(135deg, #D4A84B 0%, #B8942E 100%);">
            CANDIDATI AL PREZZO LANCIO &rarr; 497&euro;
          </button>
        </a>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-6 text-sm text-white/60">
          <div class="flex items-center gap-2">
            <!-- Zap icon -->
            <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            <span>Posti rimasti: 9/10</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Lock icon -->
            <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span>Cliente #11 paga 797&euro;</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Clock icon -->
            <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Dalla call al via: 10 giorni</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- FAQ SECTION - Light                           -->
