---
import Layout from "../layouts/Layout.astro";
import { localPath } from "../lib/i18n";

import massimoUsai from "../assets/testimonials/massimo-usai.webp";
import giacomoBrandi from "../assets/testimonials/giacomo-brandi.webp";
import danielPorro from "../assets/testimonials/daniel-porro.webp";

import bm1 from "../assets/everlogo/brand-manual-1.webp";
import bm2 from "../assets/everlogo/brand-manual-2.webp";
import bm3 from "../assets/everlogo/brand-manual-3.webp";
import bm4 from "../assets/everlogo/brand-manual-4.webp";
import bm5 from "../assets/everlogo/brand-manual-5.webp";
import bm6 from "../assets/everlogo/brand-manual-6.webp";
import bm7 from "../assets/everlogo/brand-manual-7.webp";
import bm8 from "../assets/everlogo/brand-manual-8.webp";
import bm9 from "../assets/everlogo/brand-manual-9.webp";
import bm10 from "../assets/everlogo/brand-manual-10.webp";
import bm11 from "../assets/everlogo/brand-manual-11.webp";
import bm12 from "../assets/everlogo/brand-manual-12.webp";
import bm13 from "../assets/everlogo/brand-manual-13.webp";
import bm14 from "../assets/everlogo/brand-manual-14.webp";
import bm15 from "../assets/everlogo/brand-manual-15.webp";
import bm16 from "../assets/everlogo/brand-manual-16.webp";
import bm17 from "../assets/everlogo/brand-manual-17.webp";

const lang = "en";

const slides = [
  { src: bm1.src, alt: "Brand Manual - Ortodonzia (Baghera)" },
  { src: bm2.src, alt: "Brand Manual - Energia (Casa No Gas)" },
  { src: bm3.src, alt: "Brand Manual - Immobiliare (Casa120)" },
  { src: bm4.src, alt: "Brand Manual - Ortodonzia (Faccette Pro)" },
  { src: bm5.src, alt: "Brand Manual - Ortodonzia (Forever)" },
  { src: bm6.src, alt: "Brand Manual - Beauty (Gentle Beam)" },
  { src: bm7.src, alt: "Brand Manual - Coltivazioni legali (GiaPronta)" },
  { src: bm8.src, alt: "Brand Manual - Copywriter (Hotaru42)" },
  { src: bm9.src, alt: "Brand Manual - Alimentazione animali (Kefieno)" },
  { src: bm10.src, alt: "Brand Manual - Personal Brand (Keryx)" },
  { src: bm11.src, alt: "Brand Manual - Podcast (Libertucce)" },
  { src: bm12.src, alt: "Brand Manual - Coltivazioni legali (NeverWeedOut)" },
  { src: bm13.src, alt: "Brand Manual - Profumazioni (Ofuro)" },
  { src: bm14.src, alt: "Brand Manual - Chirurgia estetica (Dr. Peron)" },
  { src: bm15.src, alt: "Brand Manual - Musica (Pheel 42)" },
  { src: bm16.src, alt: "Brand Manual - Copywriting (Propagando)" },
  { src: bm17.src, alt: "Brand Manual - Industria (Thermocore)" },
];
---

<Layout
  title="Everlogo — Your business is serious. Does your logo show it?"
  description="You've built something of value. But does your logo do justice to what you've built? Discover Everlogo: strategic visual identity from &euro;3,000."
  lang={lang}
>

  <!-- ════════════════════════════════════════════ HERO ════════════════════════════════════════════ -->
  <section class="relative min-h-[80vh] flex items-center justify-center py-20 px-6 sm:px-8 md:px-4 bg-marble overflow-hidden">
    <div class="absolute inset-0 bg-background/30"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center px-2">
      <h1 class="font-display text-[2rem] sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8 text-foreground">
        Your business is serious.
        <em class="not-italic text-coral">Does your logo show it?</em>
      </h1>

      <p class="text-base md:text-xl text-muted-foreground mb-4 max-w-2xl mx-auto leading-relaxed">
        You've built something of value. But every time you show your brand to the market &mdash; your logo, business card, website &mdash;
        <strong class="text-foreground">you feel it doesn't do justice to what you've built.</strong>
      </p>
      <p class="text-base md:text-xl text-muted-foreground mb-10 max-w-2xl mx-auto leading-relaxed">
        It's not an aesthetics problem.
        <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded font-bold">It's a positioning problem.</mark>
        And until you fix it, you're leaving money on the table <em>every day</em>.
      </p>

      <button
        id="hero-quiz-btn"
        class="btn-coral group whitespace-normal text-sm sm:text-base max-w-full inline-flex items-center gap-2"
      >
        Find out if Everlogo is for you &mdash; 2 minutes
        <svg class="w-5 h-5 flex-shrink-0 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ PROBLEMA ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 text-left">
        <div class="flex flex-col items-center gap-4 mb-8">
          <!-- AlertTriangle icon -->
          <svg class="w-8 h-8 text-coral" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center">
            The wrong logo isn't just ugly. <em class="not-italic text-coral">It costs you clients.</em>
          </h2>
        </div>

        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          When your image doesn't communicate the <strong>real value</strong> of what you do, three things happen.
        </p>

        <p class="text-lg text-foreground leading-relaxed mb-4">
          <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded">The right clients underestimate you</mark>
          before they even talk to you. The wrong ones reach out expecting <em>low prices</em>.
          And you end up <strong>competing on price</strong> instead of being chosen for who you are.
        </p>

        <p class="text-lg text-muted-foreground leading-relaxed">
          It's not your fault. It's the fault of whoever sold you a <em>logo</em> instead of a <strong>strategic visual identity</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ AGITAZIONE ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-navy">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-12 text-center">
        Three mistakes <em class="not-italic text-gold">almost everyone</em> makes.
      </h2>

      <div class="space-y-6">
        <!-- Error 1: The $200 logo -->
        <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 text-left">
          <div class="flex flex-col items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-coral/10 flex items-center justify-center">
              <!-- DollarSign icon -->
              <svg class="w-5 h-5 text-coral" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold text-foreground text-center">
              The $200 logo
            </h3>
          </div>
          <p class="text-lg text-muted-foreground leading-relaxed">
            It worked when you were small. Now that you want to grow, <strong>it makes you look like everyone else</strong>.
            The clients you want to attract notice it &mdash; <em>even if they never tell you</em>.
          </p>
        </div>

        <!-- Error 2: The creative agency -->
        <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 text-left">
          <div class="flex flex-col items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-coral/10 flex items-center justify-center">
              <!-- Palette icon -->
              <svg class="w-5 h-5 text-coral" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold text-foreground text-center">
              The creative agency
            </h3>
          </div>
          <p class="text-lg text-muted-foreground leading-relaxed">
            Moodboards, inspirations, elegant fonts. Result: something <em>aesthetically pleasing</em> that
            <strong>says nothing specific about you</strong>, that nobody remembers, that doesn't sell.
            They sold you <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded">art. Not positioning.</mark>
          </p>
        </div>

        <!-- Error 3: The AI generator -->
        <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 text-left">
          <div class="flex flex-col items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-coral/10 flex items-center justify-center">
              <!-- Bot icon -->
              <svg class="w-5 h-5 text-coral" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold text-foreground text-center">
              The AI generator
            </h3>
          </div>
          <p class="text-lg text-muted-foreground leading-relaxed">
            By definition it produces <em>generic stuff</em>. It can't build a unique identity because
            <strong>it doesn't know who you are</strong>, what differentiates you, why your best clients choose you.
            It produces average.
            <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded font-bold">You can't afford to be average.</mark>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ REFRAME ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-cream">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 text-left">
        <div class="flex flex-col items-center gap-4 mb-8">
          <!-- Lightbulb icon -->
          <svg class="w-8 h-8 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center">
            A logo isn't designed. <em class="not-italic text-coral">It's built.</em>
          </h2>
        </div>

        <p class="text-lg text-muted-foreground leading-relaxed mb-6">
          Think of Louboutin's red sole. The Coca-Cola bottle silhouette. The Susan G. Komen pink ribbon. None of these brands spend energy explaining what they do &mdash;
          <em>their visual identity says it before they open their mouths</em>.
        </p>

        <p class="text-lg leading-relaxed mb-6">
          <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded font-bold">That's what we build with Everlogo:</mark>
          <span class="text-foreground font-bold">a visual identity so precise, so uniquely yours, that it communicates your positioning without you having to say a word.</span>
        </p>

        <p class="text-lg text-muted-foreground leading-relaxed">
          We don't start with the logo. We start with <strong>who you are</strong>, with <strong>who you want to attract</strong>, with <strong>what makes you different</strong> from everyone else in your market. The logo is the <em>end</em> of the process &mdash; not the beginning.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ PACCHETTO ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-marble">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 text-left">
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-2 text-center">
          The Everlogo package &mdash;
          <span class="text-coral">&euro;3,000</span>
        </h2>
        <p class="text-lg text-muted-foreground text-center mb-10">
          It's not the cheapest logo you'll find.
          <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded font-bold">It's the last one you'll ever need.</mark>
        </p>

        <div class="space-y-5 mb-10">
          <!-- Item 1: Target -->
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-gold/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <p class="text-base text-foreground leading-relaxed">Strategic session &mdash; we analyze your market, your best clients, and the positioning you want to own</p>
          </div>
          <!-- Item 2: Package -->
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-gold/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"/><path d="M12 22V12"/><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"/></svg>
            </div>
            <p class="text-base text-foreground leading-relaxed">Complete visual identity &mdash; primary logo, variants, palette, typography, usage rules</p>
          </div>
          <!-- Item 3: BookOpen -->
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-gold/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
            </div>
            <p class="text-base text-foreground leading-relaxed">Brand Book &mdash; the document that tells everyone who you are, without you explaining it every time</p>
          </div>
          <!-- Item 4: Layout -->
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-gold/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            </div>
            <p class="text-base text-foreground leading-relaxed">Core applications &mdash; business card, letterhead, social templates, email signature</p>
          </div>
          <!-- Item 5: RefreshCw -->
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-gold/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
            </div>
            <p class="text-base text-foreground leading-relaxed">Unlimited revisions until it's right</p>
          </div>
        </div>

        <p class="text-lg text-foreground font-bold text-center">
          A <em>one-time</em> investment. An identity that works for you <mark class="bg-[hsl(48,80%,80%)] text-foreground px-1 rounded">for years</mark>.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ ESEMPI VISIVI ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-cream">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col items-center gap-4 mb-12">
        <!-- Image icon -->
        <svg class="w-8 h-8 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center">
          Recent work
        </h2>
      </div>

      <!-- Carousel -->
      <div class="relative px-10 md:px-14" id="carousel-wrapper">
        <div class="overflow-hidden" id="carousel-viewport">
          <div class="flex gap-4 transition-transform duration-500" id="carousel-track">
            {slides.map((slide, i) => (
              <div class="flex-shrink-0 w-full md:w-1/3">
                <button
                  data-lightbox-index={i}
                  class="rounded-xl overflow-hidden shadow-lg bg-white cursor-zoom-in w-full block"
                >
                  <img
                    src={slide.src}
                    alt={slide.alt}
                    class="w-full h-auto object-contain"
                    loading="lazy"
                  />
                </button>
              </div>
            ))}
          </div>
        </div>
        <!-- Carousel nav -->
        <button id="carousel-prev" class="absolute left-0 top-1/2 -translate-y-1/2 bg-white shadow-lg rounded-full p-2 hover:bg-gray-50 transition-colors z-10" aria-label="Previous">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button id="carousel-next" class="absolute right-0 top-1/2 -translate-y-1/2 bg-white shadow-lg rounded-full p-2 hover:bg-gray-50 transition-colors z-10" aria-label="Next">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox-overlay" class="fixed inset-0 z-50 bg-black/80 hidden items-center justify-center p-4">
      <button id="lightbox-close" class="absolute top-4 right-4 text-white/80 hover:text-white z-10" aria-label="Close">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <div class="relative max-w-4xl w-full">
        <img id="lightbox-img" src="" alt="" class="w-full h-auto rounded-lg select-none" draggable="false" />
        <button id="lightbox-prev" class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full p-2 transition-colors" aria-label="Previous">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button id="lightbox-next" class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full p-2 transition-colors" aria-label="Next">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <div id="lightbox-counter" class="absolute bottom-3 left-1/2 -translate-x-1/2 bg-black/50 text-white text-sm px-3 py-1 rounded-full"></div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ TESTIMONIANZE ════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 px-4 bg-navy">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-12 justify-center">
        <!-- MessageSquareQuote icon -->
        <svg class="w-7 h-7 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 12a2 2 0 0 0 2-2V8H8"/><path d="M14 12a2 2 0 0 0 2-2V8h-2"/></svg>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          What clients say
        </h2>
      </div>

      <div class="space-y-6">
        <!-- Testimonial 1 -->
        <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 text-left">
          <div class="flex gap-1 mb-4">
            <svg class="w-4 h-4 fill-gold text-gold" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg class="w-4 h-4 fill-gold text-gold" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
