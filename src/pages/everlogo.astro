<script is:inline>
(function() {
  // ── Carousel ──
  var track = document.getElementById('carousel-track');
  var prevBtn = document.getElementById('carousel-prev');
  var nextBtn = document.getElementById('carousel-next');
  var currentIndex = 0;

  function getSlidesPerView() {
    return window.innerWidth >= 768 ? 3 : 1;
  }

  function getTotalSlides() {
    return track ? track.children.length : 0;
  }

  function updateCarousel() {
    if (!track) return;
    var spv = getSlidesPerView();
    var maxIndex = Math.max(0, getTotalSlides() - spv);
    if (currentIndex > maxIndex) currentIndex = maxIndex;
    var pct = -(currentIndex * (100 / spv));
    track.style.transform = 'translateX(' + pct + '%)';
  }

  if (prevBtn) prevBtn.addEventListener('click', function() {
    currentIndex = Math.max(0, currentIndex - 1);
    updateCarousel();
  });

  if (nextBtn) nextBtn.addEventListener('click', function() {
    var spv = getSlidesPerView();
    var maxIndex = Math.max(0, getTotalSlides() - spv);
    currentIndex = Math.min(maxIndex, currentIndex + 1);
    updateCarousel();
  });

  window.addEventListener('resize', updateCarousel);

  // Auto-play
  var autoplayTimer = setInterval(function() {
    var spv = getSlidesPerView();
    var maxIndex = Math.max(0, getTotalSlides() - spv);
    currentIndex = currentIndex >= maxIndex ? 0 : currentIndex + 1;
    updateCarousel();
  }, 3000);

  // ── Lightbox ──
  var overlay = document.getElementById('lightbox-overlay');
  var lbImg = document.getElementById('lightbox-img');
  var lbCounter = document.getElementById('lightbox-counter');
  var lbPrev = document.getElementById('lightbox-prev');
  var lbNext = document.getElementById('lightbox-next');
  var lbClose = document.getElementById('lightbox-close');
  var lightboxIndex = -1;

  var slideData = [];
  var slideButtons = document.querySelectorAll('[data-lightbox-index]');
  slideButtons.forEach(function(btn) {
    var img = btn.querySelector('img');
    if (img) slideData.push({ src: img.src, alt: img.alt });
  });

  function openLightbox(idx) {
    lightboxIndex = idx;
    updateLightbox();
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    clearInterval(autoplayTimer);
  }

  function closeLightbox() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    lightboxIndex = -1;
  }

  function updateLightbox() {
    if (lightboxIndex < 0 || !slideData[lightboxIndex]) return;
    lbImg.src = slideData[lightboxIndex].src;
    lbImg.alt = slideData[lightboxIndex].alt;
    lbCounter.textContent = (lightboxIndex + 1) + ' / ' + slideData.length;
  }

  slideButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(btn.getAttribute('data-lightbox-index'));
      openLightbox(idx);
    });
  });

  if (lbClose) lbClose.addEventListener('click', closeLightbox);
  if (overlay) overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeLightbox();
  });

  if (lbPrev) lbPrev.addEventListener('click', function() {
    lightboxIndex = (lightboxIndex - 1 + slideData.length) % slideData.length;
    updateLightbox();
  });

  if (lbNext) lbNext.addEventListener('click', function() {
    lightboxIndex = (lightboxIndex + 1) % slideData.length;
    updateLightbox();
  });

  document.addEventListener('keydown', function(e) {
    if (lightboxIndex < 0) return;
    if (e.key === 'ArrowLeft') { lightboxIndex = (lightboxIndex - 1 + slideData.length) % slideData.length; updateLightbox(); }
    if (e.key === 'ArrowRight') { lightboxIndex = (lightboxIndex + 1) % slideData.length; updateLightbox(); }
    if (e.key === 'Escape') closeLightbox();
  });

  // ── Quiz ──
  var quizModal = document.getElementById('quiz-modal');
  var quizContent = document.getElementById('quiz-content');
  var quizCloseBtn = document.getElementById('quiz-close');
  var heroQuizBtn = document.getElementById('hero-quiz-btn');
  var ctaQuizBtn = document.getElementById('cta-quiz-btn');

  var questions = [
    {
      question: "When a potential client sees your logo for the first time, what do you think it communicates?",
      options: [
        { label: "Professionalism and authority in my industry", points: 0 },
        { label: "Something generic, similar to many others", points: 1 },
        { label: "I don\u2019t know \u2014 and that worries me", points: 1 }
      ]
    },
    {
      question: "Have you ever lost a client or a deal because your image didn\u2019t convey enough credibility?",
      options: [
        { label: "Probably yes, even though I\u2019m not certain", points: 1 },
        { label: "Yes, it has happened explicitly", points: 1 },
        { label: "I don\u2019t think so, and I\u2019ve never thought about it", points: 0 }
      ]
    },
    {
      question: "When you need to justify your prices to a new client, how much does your image weigh in?",
      options: [
        { label: "A lot \u2014 I know my image doesn\u2019t help me", points: 1 },
        { label: "Somewhat \u2014 sometimes I feel it doesn\u2019t support me", points: 1 },
        { label: "Not at all \u2014 my brand already communicates my value", points: 0 }
      ]
    },
    {
      question: "How long has it been since you last updated your visual identity?",
      options: [
        { label: "I\u2019ve never really done it", points: 1 },
        { label: "More than 3 years", points: 1 },
        { label: "Less than 3 years but I already feel it\u2019s not working", points: 1 }
      ]
    },
    {
      question: "If your image truly communicated the value of what you do, what would change in your business?",
      options: [
        { label: "I could finally justify higher prices", points: 1 },
        { label: "I\u2019d attract better clients without having to explain who I am", points: 1 },
        { label: "Both", points: 1 },
        { label: "Probably not much would change", points: 0 }
      ]
    }
  ];

  var currentStep = 0;
  var answers = new Array(questions.length).fill(null);
  var finished = false;

  function openQuiz() {
    currentStep = 0;
    answers = new Array(questions.length).fill(null);
    finished = false;
    renderQuiz();
    quizModal.classList.remove('hidden');
    quizModal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeQuiz() {
    quizModal.classList.add('hidden');
    quizModal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function renderQuiz() {
    if (finished) {
      var score = answers.reduce(function(sum, ansIdx, qIdx) {
        if (ansIdx === null) return sum;
        return sum + questions[qIdx].options[ansIdx].points;
      }, 0);
      var qualified = score >= 3;

      if (qualified) {
        quizContent.innerHTML =
          '<div class="text-center max-w-2xl mx-auto">' +
            '<svg class="w-12 h-12 text-accent mx-auto mb-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>' +
            '<h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4">You\u2019re in the right place.</h2>' +
            '<p class="text-lg text-muted-foreground mb-8 max-w-xl mx-auto leading-relaxed">' +
              'Your answers confirm what you suspected: your current image isn\u2019t working for you the way it should.' +
              '<br><br><strong class="text-foreground">Book a free call with Davide.</strong> In 30 minutes we\u2019ll analyze your situation and you\u2019ll know exactly what to do.' +
            '</p>' +
            '<a href="https://calendar.app.google/kSWASczvKmtVY83YA" target="_blank" rel="noopener noreferrer" class="btn-coral group inline-flex items-center gap-2">' +
              'Book the free call' +
              '<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>' +
            '</a>' +
          '</div>';
      } else {
        quizContent.innerHTML =
          '<div class="text-center max-w-2xl mx-auto">' +
            '<svg class="w-12 h-12 text-muted-foreground mx-auto mb-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>' +
            '<h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4">Right now, Everlogo isn\u2019t for you.</h2>' +
            '<p class="text-lg text-muted-foreground max-w-xl mx-auto leading-relaxed">' +
              'If your brand already communicates your value, you don\u2019t need us \u2014 and it wouldn\u2019t make sense to waste your time with a call.' +
              '<br><br>If things change, you know where to find us.' +
            '</p>' +
          '</div>';
      }
      return;
    }

    var q = questions[currentStep];
    var html =
      '<div class="text-center max-w-2xl mx-auto">' +
        '<h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">Find out if Everlogo is for you.</h2>' +
        '<p class="text-muted-foreground mb-10">Answer 5 questions.</p>' +
        '<div class="bg-card border border-border rounded-2xl p-6 md:p-10 text-left">' +
          '<p class="text-sm text-muted-foreground mb-2 font-medium">Question ' + (currentStep + 1) + ' of ' + questions.length + '</p>' +
          '<h3 class="font-display text-lg md:text-xl font-semibold text-foreground mb-6 leading-snug">' + q.question + '</h3>' +
          '<div class="space-y-3 mb-8">';

    q.options.forEach(function(opt, i) {
      var selected = answers[currentStep] === i;
      var cls = selected
        ? 'border-coral bg-coral/10 text-foreground font-medium'
        : 'border-border bg-background text-muted-foreground hover:border-muted-foreground/40';
      html += '<button data-quiz-option="' + i + '" class="w-full text-left px-5 py-4 rounded-xl border-2 transition-all duration-200 text-sm md:text-base leading-relaxed ' + cls + '">' + opt.label + '</button>';
    });

    var isLast = currentStep >= questions.length - 1;
    var disabled = answers[currentStep] === null ? 'opacity-50 pointer-events-none' : '';
    html +=
          '</div>' +
          '<div class="flex justify-end">' +
            '<button id="quiz-next-btn" class="btn-coral group inline-flex items-center gap-2 ' + disabled + '">' +
              (isLast ? 'See result' : 'Next') +
              '<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>' +
            '</button>' +
          '</div>' +
        '</div>' +
      '</div>';

    quizContent.innerHTML = html;

    // Bind option clicks
    quizContent.querySelectorAll('[data-quiz-option]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        answers[currentStep] = parseInt(btn.getAttribute('data-quiz-option'));
        renderQuiz();
      });
    });

    // Bind next
    var nextBtnQ = document.getElementById('quiz-next-btn');
    if (nextBtnQ) nextBtnQ.addEventListener('click', function() {
      if (answers[currentStep] === null) return;
      if (currentStep < questions.length - 1) {
        currentStep++;
        renderQuiz();
      } else {
        finished = true;
        renderQuiz();
      }
    });
  }

  if (heroQuizBtn) heroQuizBtn.addEventListener('click', openQuiz);
  if (ctaQuizBtn) ctaQuizBtn.addEventListener('click', openQuiz);
  if (quizCloseBtn) quizCloseBtn.addEventListener('click', closeQuiz);
  if (quizModal) quizModal.addEventListener('click', function(e) {
    if (e.target === quizModal) closeQuiz();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !quizModal.classList.contains('hidden')) closeQuiz();
  });
})();
</script>
