---
import Layout from "../layouts/Layout.astro";

const lang = "en";
---

<Layout
  title="What is DRD | Keryx Design"
  description="Discover what Direct Response Design is and how it can help your business."
  lang={lang}
>
  <section class="bg-marble py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] mb-8 text-foreground">
          What is DRD
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
          Content coming soon...
        </p>
      </div>
    </div>
  </section>
</Layout>
