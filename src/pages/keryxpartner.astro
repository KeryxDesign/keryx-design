            </div>
          </div>
          <!-- Step 4 -->
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy text-primary-foreground flex items-center justify-center font-bold text-lg">4</div>
