---
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  image: string;
  date: string;
  category: string;
  categoryLabel: string;
  readTime: number | null;
  href: string;
  lang: "it" | "en";
  featured?: boolean;
}

const { slug, title, excerpt, image, date, category, categoryLabel, readTime, href, lang, featured = false } = Astro.props;

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString(lang === "it" ? "it-IT" : "en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
};

const readMoreLabel = lang === "it" ? "Leggi" : "Read";
const minLabel = "min";
---

{featured ? (
  <a href={href} class="group block">
    <div class="grid md:grid-cols-2 gap-8 bg-card rounded-2xl overflow-hidden border border-border hover:border-gold/50 transition-colors">
      <div class="aspect-video md:aspect-[4/3] relative overflow-hidden bg-muted/30">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover md:object-contain"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="p-8 flex flex-col justify-center">
        <span class="text-sm text-gold-dark font-medium mb-2">{categoryLabel}</span>
        <h2 class="text-2xl md:text-3xl font-display font-medium text-foreground mb-4 group-hover:text-gold-dark transition-colors">
          {title}
        </h2>
        <p class="text-muted-foreground mb-6 leading-relaxed">
          {excerpt}
        </p>
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-4 text-sm text-muted-foreground">
            {date && (
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {formatDate(date)}
              </span>
            )}
            {readTime && (
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {readTime} {minLabel}
              </span>
            )}
          </div>
          <span class="flex items-center gap-2 text-gold-dark font-medium group-hover:gap-3 transition-all">
            {readMoreLabel}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </div>
  </a>
) : (
  <a href={href} class="group bg-card rounded-xl overflow-hidden border border-border hover:border-gold/50 transition-colors">
    <div class="aspect-video relative overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="p-6">
      <span class="text-xs text-gold-dark font-medium">{categoryLabel}</span>
      <h4 class="text-lg font-medium text-foreground mt-2 mb-3 group-hover:text-gold-dark transition-colors line-clamp-2">
        {title}
      </h4>
      <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
        {excerpt}
      </p>
      <div class="flex items-center gap-4 text-xs text-muted-foreground">
        {date && (
          <span class="flex items-center gap-1">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {formatDate(date)}
          </span>
        )}
        {readTime && (
          <span class="flex items-center gap-1">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {readTime} {minLabel}
          </span>
        )}
      </div>
    </div>
  </a>
)}
