---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-text">&copy; {year} Keryx Design. Tutti i diritti riservati.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-text {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
