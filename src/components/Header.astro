---
import type { Language } from "../lib/i18n";
import { localPath } from "../lib/i18n";
import logo from "../assets/keryx-logo.svg";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const logoSrc = typeof logo === "string" ? logo : logo.src;

const whatsappMsg = encodeURIComponent(
  lang === "it"
    ? "Ciao, vorrei parlare dei vostri servizi di design"
    : "Hello, I'd like to talk about your design services"
);

const aboutItems =
  lang === "it"
    ? [
        { label: "Chi Siamo", href: localPath("/about", lang) },
        { label: "Come Lavoriamo", href: localPath("/come-lavoriamo", lang) },
        { label: "Portfolio", href: localPath("/portfolio", lang) },
      ]
    : [
        { label: "About Us", href: localPath("/about", lang) },
        { label: "Portfolio", href: localPath("/portfolio", lang) },
      ];

const servicesItems =
  lang === "it"
    ? [
        { label: "Keryx Partner", href: localPath("/keryxpartner", lang) },
        { label: "Everlogo", href: localPath("/everlogo", lang) },
        { label: "Listino Prezzi", href: localPath("/listino", lang) },
      ]
    : [
        { label: "Keryx Partner", href: localPath("/keryxpartner", lang) },
        { label: "Everlogo", href: localPath("/everlogo", lang) },
        { label: "Price List", href: localPath("/pricelist", lang) },
      ];

const directLinks = [
  {
    label: lang === "it" ? "Testimonianze" : "Testimonials",
    href: lang === "it" ? localPath("/testimonianze", lang) : localPath("/testimonials", lang),
  },
  {
    label: lang === "it" ? "Casi Studio" : "Case Studies",
    href: localPath("/blog/case-studies", lang),
  },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur-md border-b border-border"
>
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={localPath("/", lang)}
        class="hover:opacity-80 transition-opacity"
      >
        <img src={logoSrc} alt="Keryx Design" class="h-8 md:h-10" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <!-- About Dropdown -->
        <div class="relative">
          <button
            class="nav-dropdown-btn flex items-center gap-1 text-muted-foreground hover:text-primary transition-colors text-sm font-medium"
            aria-expanded="false"
          >
            About
            <svg
              class="w-4 h-4 transition-transform"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>
          <div
            class="nav-dropdown hidden absolute top-full left-0 mt-2 bg-background border border-border rounded-lg shadow-lg py-2 min-w-[220px]"
          >
            {
              aboutItems.map((item) => (
                <a
                  href={item.href}
                  class="block px-4 py-2 text-sm text-muted-foreground hover:text-primary hover:bg-muted/50 transition-colors"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Services Dropdown -->
        <div class="relative">
          <button
            class="nav-dropdown-btn flex items-center gap-1 text-muted-foreground hover:text-primary transition-colors text-sm font-medium"
            aria-expanded="false"
          >
            {lang === "it" ? "Servizi" : "Services"}
            <svg
              class="w-4 h-4 transition-transform"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>
          <div
            class="nav-dropdown hidden absolute top-full left-0 mt-2 bg-background border border-border rounded-lg shadow-lg py-2 min-w-[220px]"
          >
            {
              servicesItems.map((item) => (
                <a
                  href={item.href}
                  class="block px-4 py-2 text-sm text-muted-foreground hover:text-primary hover:bg-muted/50 transition-colors"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Direct Links -->
        {
          directLinks.map((item) => (
            <a
              href={item.href}
              class="text-muted-foreground hover:text-primary transition-colors text-sm font-medium"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <!-- WhatsApp CTA (desktop) -->
        <a
          href={`https://wa.me/3550695822380?text=${whatsappMsg}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <button
            class="hidden md:flex items-center font-bold text-white gap-2 px-4 py-2 rounded-md text-sm"
            style="background: linear-gradient(135deg, #25D366 0%, #128C7E 100%)"
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            {lang === "it" ? "Parla con noi" : "Talk to us"}
          </button>
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-foreground"
          aria-label="Toggle menu"
        >
          <svg
            id="menu-icon"
            class="w-6 h-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg
            id="close-icon"
            class="w-6 h-6 hidden"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav
      id="mobile-nav"
      class="md:hidden hidden py-4 border-t border-border bg-background"
    >
      <div class="flex flex-col gap-4">
        <!-- About Dropdown (mobile) -->
        <div class="flex flex-col">
          <button
            class="mobile-dropdown-btn flex items-center justify-between text-foreground hover:text-primary transition-colors text-sm font-medium py-2"
          >
            About
            <svg
              class="w-4 h-4 transition-transform"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>
          <div class="mobile-dropdown hidden pl-4 flex flex-col gap-2">
            {
              aboutItems.map((item) => (
                <a
                  href={item.href}
                  class="mobile-nav-link text-muted-foreground hover:text-primary transition-colors text-sm py-1"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Services Dropdown (mobile) -->
        <div class="flex flex-col">
          <button
            class="mobile-dropdown-btn flex items-center justify-between text-foreground hover:text-primary transition-colors text-sm font-medium py-2"
          >
            {lang === "it" ? "Servizi" : "Services"}
            <svg
              class="w-4 h-4 transition-transform"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>
          <div class="mobile-dropdown hidden pl-4 flex flex-col gap-2">
            {
              servicesItems.map((item) => (
                <a
                  href={item.href}
                  class="mobile-nav-link text-muted-foreground hover:text-primary transition-colors text-sm py-1"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Direct Links (mobile) -->
        {
          directLinks.map((item) => (
            <a
              href={item.href}
              class="mobile-nav-link text-foreground hover:text-primary transition-colors text-sm font-medium py-2"
            >
              {item.label}
            </a>
          ))
        }

        <!-- WhatsApp CTA (mobile) -->
        <a
          href={`https://wa.me/3550695822380?text=${whatsappMsg}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <button
            class="mt-2 w-fit flex items-center font-bold text-white gap-2 px-4 py-2 rounded-md text-sm"
            style="background: linear-gradient(135deg, #25D366 0%, #128C7E 100%)"
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            {lang === "it" ? "Parla con noi" : "Talk to us"}
          </button>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Desktop dropdown toggles
  document.querySelectorAll(".nav-dropdown-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const dropdown = btn.nextElementSibling as HTMLElement;
      const isOpen = !dropdown.classList.contains("hidden");

      // Close all dropdowns
      document.querySelectorAll(".nav-dropdown").forEach((d) => {
        d.classList.add("hidden");
      });
      document.querySelectorAll(".nav-dropdown-btn").forEach((b) => {
        b.setAttribute("aria-expanded", "false");
        const chevron = b.querySelector("svg");
        chevron?.classList.remove("rotate-180");
      });

      // Toggle current
      if (!isOpen) {
        dropdown.classList.remove("hidden");
        btn.setAttribute("aria-expanded", "true");
        const chevron = btn.querySelector("svg");
        chevron?.classList.add("rotate-180");
      }
    });
  });

  // Close desktop dropdowns on outside click
  document.addEventListener("click", (e) => {
    const target = e.target as Element;
    if (
      !target.closest(".nav-dropdown-btn") &&
      !target.closest(".nav-dropdown")
    ) {
      document.querySelectorAll(".nav-dropdown").forEach((d) => {
        d.classList.add("hidden");
      });
      document.querySelectorAll(".nav-dropdown-btn").forEach((b) => {
        b.setAttribute("aria-expanded", "false");
        const chevron = b.querySelector("svg");
        chevron?.classList.remove("rotate-180");
      });
    }
  });

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileNav = document.getElementById("mobile-nav");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileNav?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });

  // Mobile dropdown toggles
  document.querySelectorAll(".mobile-dropdown-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dropdown = btn.nextElementSibling as HTMLElement;
      dropdown?.classList.toggle("hidden");
      const chevron = btn.querySelector("svg");
      chevron?.classList.toggle("rotate-180");
    });
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileNav?.classList.add("hidden");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });
</script>
